  <Code>Public Function MultiParamValues(ByVal param As String, ByVal maxEntries As Integer) AS String
    Dim paramValues() As String
    Dim numSelected As Integer
    Dim returnValue As String
    Dim i As Integer
    returnValue = ""

    Try
        paramValues = param.split(", ")
        numSelected = paramValues.Length
	
	If Array.IndexOf(paramValues, "ALL") &gt;= 0 Then
		Return "All"
	ElseIf Array.IndexOf(paramValues, "-1") &gt;= 0 Then
		Return "All"
	Else
        	If (maxEntries &gt; numSelected) THEN
            		maxEntries = numSelected
        	End If

        	If (numSelected &gt; 5) Then
            		For i = 0 To maxEntries - 1
                	returnValue += ", " + paramValues(i).ToString()
            		Next
            		Return returnValue + "..."
        	Else
            		For i = 0 To numSelected - 1
                		returnValue += ", " + paramValues(i).ToString()
            		Next
            		Return returnValue
        	End If
	End If
    Catch
        Return "Error"
    End Try
End Function

Public Function FormatPercent(ByVal cellValue As DECIMAL) AS String
    Dim returnValue As String

    Try
        IF (ROUND(cellValue, 2) = 0.00) THEN
            returnValue = "0%"
        ELSEIF (ROUND(cellValue, 2) = 1.00) THEN
            returnValue = "0%"
        ELSE
            returnValue = "0.0%"
        END IF
        
        Return returnValue
    Catch
        Return "Error"
    End Try
End Function

Function OpenURL(ByVal URL As String) As String
    Return "javascript:void(window.open('" &amp; System.Uri.EscapeDataString(URL) &amp; "','_blank'))"
End Function</Code>
