  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="ADB_HCUKReports">
      <DataSourceReference>ADB_HCUKReports</DataSourceReference>
      <rd:SecurityType>Windows</rd:SecurityType>
      <rd:DataSourceID>1b82cd94-8454-486e-89d5-52e7b263a15d</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="XXX001a">
      <Query>
        <DataSourceName>ADB_HCUKReports</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Faculty">
            <Value>=Parameters!Faculty.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Team">
            <Value>=Parameters!Team.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Course">
            <Value>=Parameters!Course.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@NVQLevel">
            <Value>=Parameters!NVQLevel.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FundingModel">
            <Value>=Parameters!FundingModel.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OfferingType">
            <Value>=Parameters!OfferingType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EnrolmentType">
            <Value>=Parameters!EnrolmentType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AgeGroup">
            <Value>=Parameters!AgeGroup.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CompletionStatus">
            <Value>=Parameters!CompletionStatus.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear VARCHAR(5) = '22/23'
DECLARE @Faculty VARCHAR(50) = 'ALL'
DECLARE @Team VARCHAR(50) = 'ALL'
DECLARE @Course VARCHAR(50) = 'ALL'
DECLARE @NVQLevel VARCHAR(50) = 'ALL'
DECLARE @FundingModel VARCHAR(50) = 'ALL'
DECLARE @OfferingType VARCHAR(50) = 0
DECLARE @EnrolmentType VARCHAR(50) = 0
DECLARE @AgeGroup VARCHAR(50) = 'ALL'
DECLARE @CompletionStatus VARCHAR(50) = 'ALL'
*/

--Enrolments
DROP TABLE IF EXISTS #Enrols
SELECT
	AcademicYear = SD.AcademicYearID,
	FacultyCode = RTRIM ( FAC.Code ),
	FacultyName = FAC.Name,
	TeamCode = RTRIM ( TEAM.Code ),
	TeamName = TEAM.Name,
	StudentRef = SD.RefNo,
	StudentDetailID = SD.StudentDetailID,
	Surname = SD.Surname,
	Forename = SD.FirstForename,
	Age31Aug = 
		CASE
			WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
			ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
		END,
	AgeGroup = 
		CASE
			WHEN 
				CASE
					WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
					ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
				END 
				&lt; 16 THEN '14-15'
			WHEN 
				CASE
					WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
					ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
				END 
				BETWEEN 16 AND 18 THEN '16-18'
			WHEN 
				CASE
					WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
					ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
				END BETWEEN 19 AND 24 THEN '19-24'
			WHEN 
				CASE
					WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
					ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
				END &gt;= 25 THEN '25+'
		END,
	CourseCode = CRS.Code,
	CourseTitle = CRS.Name,
	AimCode = CRS.QualID,
	AimTitle = AIM.LEARNING_AIM_TITLE,
	NVQLevelCode = COALESCE ( AIM.NVQLevelID_v2, 'X' ),
	NVQLevelName = 
		CASE
			WHEN COALESCE ( AIM.NVQLevelID_v2, 'X' ) = 'E' THEN 'Entry Level'
			ELSE 'Level ' + COALESCE ( AIM.NVQLevelID_v2, 'X' )
		END,
	NVQLevelSort = 
		CASE
			WHEN COALESCE ( AIM.NVQLevelID_v2, 'X' ) = 'E' THEN 0
			WHEN COALESCE ( AIM.NVQLevelID_v2, 'X' ) = 'X' THEN -1
			ELSE TRY_CAST ( AIM.NVQLevelID_v2 AS INT )
		END,
	FundingModelCode = 
		CASE
			WHEN 
				ENR.FundingID = '25'
				AND
					CASE
						WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
						ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
					END &lt;= 15
					THEN '14-15'
			WHEN 
				ENR.FundingID = '99'
				AND
					CASE
						WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
						ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
					END &lt;= 15
					THEN 'SchoolLinks'
			WHEN ENR.FundingID = '25' AND ENR.ProgrammeTypeID = '31' THEN 'TLevel'
			WHEN ENR.FundingID = '25' THEN '16-19'
			WHEN ENR.IsAdvancedLearningLoanFunded = 1 THEN 'AdvLoan'
			WHEN ENR.FundingID = '36' THEN 'App' --Standard
			WHEN ENR.FundingID IN ( '35', '36' ) AND POT.ProgrammeTypeID = '25' THEN 'App' --Standard
			WHEN ENR.FundingID IN ( '35', '36' ) AND POT.ProgrammeTypeID IS NOT NULL THEN 'App' --Framework
			WHEN AIM.NVQLevelID_v2 IN ( '4', '5', '6', '7', '8' ) THEN 'HE-Other'
			WHEN ENR.FundingID = '35' AND ENR.MajorFundingSourceID = '105' THEN 'AEB-ESFA'
			WHEN ENR.FundingID = '35' THEN 'AEB-Dev'
			WHEN ENR.MajorFundingSourceID = '001' THEN 'HE-HEFCE'
			WHEN ENR.MajorFundingSourceID = '002' THEN 'HE-Fran' --Need to check this
			WHEN ENR.FundingID = '10' THEN 'ComLearn'
			WHEN ENR.FundingID = '99' THEN 'NoFund'
		END,
	FundingModelName = 
		CASE
			WHEN 
				ENR.FundingID = '25'
				AND
					CASE
						WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
						ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
					END &lt;= 15
					THEN '14-15 Funded Students'
			WHEN 
				ENR.FundingID = '99'
				AND
					CASE
						WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
						ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
					END &lt;= 15
					THEN 'School Links'
			WHEN ENR.FundingID = '25' AND ENR.ProgrammeTypeID = '31' THEN 'T Level'
			WHEN ENR.FundingID = '25' THEN '16-19 Students (inc. High Needs)'
			WHEN ENR.IsAdvancedLearningLoanFunded = 1 THEN 'Adv Learner Loan'
			WHEN ENR.FundingID = '36' THEN 'Apprenticeship'
			WHEN ENR.FundingID IN ( '35', '36' ) AND POT.ProgrammeTypeID = '25' THEN 'Apprenticeship'
			WHEN ENR.FundingID IN ( '35', '36' ) AND POT.ProgrammeTypeID IS NOT NULL THEN 'Apprenticeship'
			WHEN AIM.NVQLevelID_v2 IN ( '4', '5', '6', '7', '8' ) THEN 'HE Non-Prescribed'
			WHEN ENR.FundingID = '35' AND ENR.MajorFundingSourceID = '105' THEN 'AEB Adult - ESFA'
			WHEN ENR.FundingID = '35' THEN 'AEB Adult - Devolved'
			WHEN ENR.MajorFundingSourceID = '001' THEN 'HE - HEFCE'
			WHEN ENR.MajorFundingSourceID = '002' THEN 'HE - Franchised' --Need to check this
			WHEN ENR.FundingID = '10' THEN 'Community Learning'
			WHEN ENR.FundingID = '99' THEN 'Not Funded'
		END,
	CompletionCode = ENR.CompletionStatusID,
	CompletionName = CMP.Description,
	OutcomeCode = ENR.OutcomeID,
	OutcomeName = OC.Description,
	StartDate = ENR.StartDate,
	ExpEndDate = ENR.ExpectedEndDate,
	ActEndDate = ENR.ActualEndDate
	INTO #Enrols
FROM ProSolution.dbo.StudentDetail SD
INNER JOIN ProSolution.dbo.Enrolment ENR
	ON ENR.StudentDetailID = SD.StudentDetailID
INNER JOIN ProSolution.dbo.Offering CRS
	ON CRS.OfferingID = ENR.OfferingID
INNER JOIN ProSolution.dbo.CollegeLevel TEAM
	ON TEAM.SID = CRS.SID
INNER JOIN ProSolution.dbo.CollegeLevel FAC
	ON FAC.SID = TEAM.ParentSID
INNER JOIN ProSolution.dbo.CompletionStatus CMP
	ON CMP.CompletionStatusID = ENR.CompletionStatusID
LEFT JOIN ProSolution.dbo.Outcome OC
	ON OC.OutcomeID = ENR.OutcomeID
LEFT JOIN ProSolution.dbo.WBLPeriodOFTraining POT
	ON POT.WBLPeriodOfTrainingID = ENR.WBLPeriodOfTrainingID
LEFT JOIN ProSolution.dbo.Learning_Aim AIM
	ON AIM.LEARNING_AIM_REF = CRS.QualID
WHERE
	SD.AcademicYearID = @AcademicYear
	AND ( RTRIM ( FAC.Code ) IN ( @Faculty ) OR 'ALL' IN ( @Faculty ) )
    AND ( RTRIM ( TEAM.Code ) IN ( @Team ) OR 'ALL' IN ( @Team ) )
	AND ( CRS.Code IN ( @Course ) OR 'ALL' IN ( @Course ) )
	AND ( COALESCE ( AIM.NVQLevelID_v2, 'X' ) IN ( @NVQLevel ) OR 'ALL' IN ( @NVQLevel ) )
	AND (
		CASE
			WHEN 
				ENR.FundingID = '25'
				AND
					CASE
						WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
						ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
					END &lt;= 15
					THEN '14-15'
			WHEN 
				ENR.FundingID = '99'
				AND
					CASE
						WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
						ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
					END &lt;= 15
					THEN 'SchoolLinks'
			WHEN ENR.FundingID = '25' AND ENR.ProgrammeTypeID = '31' THEN 'TLevel'
			WHEN ENR.FundingID = '25' THEN '16-19'
			WHEN ENR.IsAdvancedLearningLoanFunded = 1 THEN 'AdvLoan'
			WHEN ENR.FundingID = '36' THEN 'App' --Standard
			WHEN ENR.FundingID IN ( '35', '36' ) AND POT.ProgrammeTypeID = '25' THEN 'App' --Standard
			WHEN ENR.FundingID IN ( '35', '36' ) AND POT.ProgrammeTypeID IS NOT NULL THEN 'App' --Framework
			WHEN AIM.NVQLevelID_v2 IN ( '4', '5', '6', '7', '8' ) THEN 'HE-Other'
			WHEN ENR.FundingID = '35' AND ENR.MajorFundingSourceID = '105' THEN 'AEB-ESFA'
			WHEN ENR.FundingID = '35' THEN 'AEB-Dev'
			WHEN ENR.MajorFundingSourceID = '001' THEN 'HE-HEFCE'
			WHEN ENR.MajorFundingSourceID = '002' THEN 'HE-Fran' --Need to check this
			WHEN ENR.FundingID = '10' THEN 'ComLearn'
			WHEN ENR.FundingID = '99' THEN 'NoFund'
		END IN ( @FundingModel )
		OR 'ALL' IN ( @FundingModel )
		)
	AND ( CRS.OfferingTypeID IN ( @OfferingType ) OR 0 IN ( @OfferingType ) )
	AND ( CRS.EnrolmentTypeID IN ( @EnrolmentType ) OR 0 IN ( @EnrolmentType ) )
	AND (
		CASE
			WHEN 
				CASE
					WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
					ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
				END 
				&lt; 16 THEN '14-15'
			WHEN 
				CASE
					WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
					ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
				END 
				BETWEEN 16 AND 18 THEN '16-18'
			WHEN 
				CASE
					WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
					ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
				END BETWEEN 19 AND 24 THEN '19-24'
			WHEN 
				CASE
					WHEN MONTH ( SD.DateOfBirth ) &lt;= 8 THEN '20' + LEFT ( SD.AcademicYearID, 2 ) - YEAR ( SD.DateOfBirth )
					ELSE CAST ('20' + LEFT ( SD.AcademicYearID, 2 ) AS INT ) - 1 - YEAR ( SD.DateOfBirth )
				END &gt;= 25 THEN '25+'
		END IN ( @AgeGroup )
		OR 'ALL' IN ( @AgeGroup )
	)
	AND ( ENR.CompletionStatusID IN ( @CompletionStatus ) OR 'ALL' IN ( @CompletionStatus ) )
--ORDER BY
--	SD.AcademicYearID,
--	RTRIM ( FAC.Code ),
--	RTRIM ( TEAM.Code ),
--	SD.Surname,
--	SD.FirstForename,
--	SD.RefNo,
--	CRS.Code



--Summary Query
SELECT
	ENR.AcademicYear,
	ENR.FacultyCode,
	ENR.FacultyName,
	ENR.TeamCode,
	ENR.TeamName,
	ENR.CourseCode,
	ENR.CourseTitle,
	ENR.AimCode,
	ENR.AimTitle,
	ENR.NVQLevelCode,
	ENR.NVQLevelName,
	ENR.FundingModelCode,
	ENR.FundingModelName,
	EnrolsActive = SUM ( CASE WHEN ENR.CompletionCode = '1' THEN 1 ELSE 0 END ),
	EnrolsCompleted = SUM ( CASE WHEN ENR.CompletionCode = '2' THEN 1 ELSE 0 END ),
	EnrolsWithdrawn = SUM ( CASE WHEN ENR.CompletionCode = '3' THEN 1 ELSE 0 END ),
	EnrolsTransferred = SUM ( CASE WHEN ENR.CompletionCode = '4' THEN 1 ELSE 0 END ),
	EnrolsBreakInLearning = SUM ( CASE WHEN ENR.CompletionCode = '6' THEN 1 ELSE 0 END )
FROM #Enrols ENR
GROUP BY
	ENR.AcademicYear,
	ENR.FacultyCode,
	ENR.FacultyName,
	ENR.TeamCode,
	ENR.TeamName,
	ENR.CourseCode,
	ENR.CourseTitle,
	ENR.AimCode,
	ENR.AimTitle,
	ENR.NVQLevelCode,
	ENR.NVQLevelName,
	ENR.FundingModelCode,
	ENR.FundingModelName
ORDER BY
	ENR.AcademicYear,
	ENR.FacultyCode,
	ENR.TeamCode,
	ENR.CourseCode



/*
--Detail Query
SELECT
	ENR.AcademicYear,
	ENR.FacultyCode,
	ENR.FacultyName,
	ENR.TeamCode,
	ENR.TeamName,
	ENR.StudentRef,
	ENR.StudentDetailID,
	ENR.Surname,
	ENR.Forename,
	ENR.Age31Aug,
	ENR.AgeGroup,
	ENR.CourseCode,
	ENR.CourseTitle,
	ENR.AimCode,
	ENR.AimTitle,
	ENR.NVQLevelCode,
	ENR.NVQLevelName,
	ENR.NVQLevelSort,
	ENR.FundingModelCode,
	ENR.FundingModelName,
	ENR.CompletionCode,
	ENR.CompletionName,
	ENR.OutcomeCode,
	ENR.OutcomeName,
	ENR.StartDate,
	ENR.ExpEndDate,
	ENR.ActEndDate
FROM #Enrols ENR
ORDER BY
	ENR.AcademicYear,
	ENR.FacultyCode,
	ENR.TeamCode,
	ENR.Surname,
	ENR.Forename,
	ENR.StudentRef,
	ENR.CourseCode
*/</CommandText>
      </Query>
      <Fields>
        <Field Name="AcademicYear">
          <DataField>AcademicYear</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FacultyCode">
          <DataField>FacultyCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FacultyName">
          <DataField>FacultyName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TeamCode">
          <DataField>TeamCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TeamName">
          <DataField>TeamName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CourseCode">
          <DataField>CourseCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CourseTitle">
          <DataField>CourseTitle</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AimCode">
          <DataField>AimCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AimTitle">
          <DataField>AimTitle</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NVQLevelCode">
          <DataField>NVQLevelCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NVQLevelName">
          <DataField>NVQLevelName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FundingModelCode">
          <DataField>FundingModelCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FundingModelName">
          <DataField>FundingModelName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EnrolsActive">
          <DataField>EnrolsActive</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="EnrolsCompleted">
          <DataField>EnrolsCompleted</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="EnrolsWithdrawn">
          <DataField>EnrolsWithdrawn</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="EnrolsTransferred">
          <DataField>EnrolsTransferred</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="EnrolsBreakInLearning">
          <DataField>EnrolsBreakInLearning</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="AcademicYear">
      <Query>
        <DataSourceName>ADB_HCUKReports</DataSourceName>
        <CommandText>SELECT
	Code = AY.AcademicYearID,
	Description = AY.Description
FROM ProSolution.dbo.AcademicYear AY
WHERE
	AY.Enabled = 1
ORDER BY
	AY.AcademicYearID</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="AcademicYearCur">
      <Query>
        <DataSourceName>ADB_HCUKReports</DataSourceName>
        <CommandText>SELECT
	Code = AY.AcademicYearID,
	Description = AY.Description
FROM ProSolution.dbo.AcademicYear AY
WHERE
	AY.Enabled = 1
	AND CAST ( AY.StartDate AS DATE ) &lt;= CAST ( GetDate() AS DATE )
	AND CAST ( AY.EndDate AS DATE ) &gt;= CAST ( GetDate() AS DATE )
ORDER BY
	AY.AcademicYearID</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Faculty">
      <Query>
        <DataSourceName>ADB_HCUKReports</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear VARCHAR(5) = '22/23'
*/

SELECT
	Code = 'ALL',
	Description = '-- All Faculties --'

UNION ALL

SELECT DISTINCT
	Code = RTRIM ( FAC.Code ),
	Description = RTRIM ( FAC.Code ) + ' - ' + FAC.Name
FROM ProSolution.dbo.StudentDetail SD
INNER JOIN ProSolution.dbo.Enrolment ENR
	ON ENR.StudentDetailID = SD.StudentDetailID
INNER JOIN ProSolution.dbo.Offering CRS
	ON CRS.OfferingID = ENR.OfferingID
INNER JOIN ProSolution.dbo.CollegeLevel TEAM
	ON TEAM.SID = CRS.SID
INNER JOIN ProSolution.dbo.CollegeLevel FAC
	ON FAC.SID = TEAM.ParentSID
WHERE
	CRS.AcademicYearID = @AcademicYear
	AND ENR.CompletionStatusID IN ( '1', '2', '3' )

ORDER BY
	Code</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Team">
      <Query>
        <DataSourceName>ADB_HCUKReports</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Faculty">
            <Value>=Parameters!Faculty.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear VARCHAR(5) = '22/23'
DECLARE @Faculty VARCHAR(50) = 'ALL'
*/

SELECT
	Code = 'ALL',
	Description = '-- All Teams --'

UNION ALL

SELECT DISTINCT
	Code = RTRIM ( TEAM.Code ),
	Description = RTRIM ( TEAM.Code ) + ' - ' + TEAM.Name
FROM ProSolution.dbo.StudentDetail SD
INNER JOIN ProSolution.dbo.Enrolment ENR
	ON ENR.StudentDetailID = SD.StudentDetailID
INNER JOIN ProSolution.dbo.Offering CRS
	ON CRS.OfferingID = ENR.OfferingID
INNER JOIN ProSolution.dbo.CollegeLevel TEAM
	ON TEAM.SID = CRS.SID
INNER JOIN ProSolution.dbo.CollegeLevel FAC
	ON FAC.SID = TEAM.ParentSID
WHERE
	CRS.AcademicYearID = @AcademicYear
	AND ENR.CompletionStatusID IN ( '1', '2', '3' )
	AND ( RTRIM ( FAC.Code ) IN ( @Faculty ) OR 'ALL' IN ( @Faculty ) )

ORDER BY
	Code</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Course">
      <Query>
        <DataSourceName>ADB_HCUKReports</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Faculty">
            <Value>=Parameters!Faculty.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Team">
            <Value>=Parameters!Team.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear VARCHAR(5) = '22/23'
DECLARE @Faculty VARCHAR(50) = 'ALL'
DECLARE @Team VARCHAR(50) = 'ALL'
*/

SELECT
	Code = 'ALL',
	Description = '-- All Courses --'

UNION ALL

SELECT DISTINCT
	Code = CRS.Code,
	Description = RTRIM ( FAC.Code ) + ' &gt; ' + RTRIM ( TEAM.Code ) + ' &gt; ' + CRS.Code + ' - ' + CRS.Name
FROM ProSolution.dbo.StudentDetail SD
INNER JOIN ProSolution.dbo.Enrolment ENR
	ON ENR.StudentDetailID = SD.StudentDetailID
INNER JOIN ProSolution.dbo.Offering CRS
	ON CRS.OfferingID = ENR.OfferingID
INNER JOIN ProSolution.dbo.CollegeLevel TEAM
	ON TEAM.SID = CRS.SID
INNER JOIN ProSolution.dbo.CollegeLevel FAC
	ON FAC.SID = TEAM.ParentSID
WHERE
	CRS.AcademicYearID = @AcademicYear
	AND ENR.CompletionStatusID IN ( '1', '2', '3' )
	AND ( RTRIM ( FAC.Code ) IN ( @Faculty ) OR 'ALL' IN ( @Faculty ) )
	AND ( RTRIM ( TEAM.Code ) IN ( @Team ) OR 'ALL' IN ( @Team ) )

ORDER BY
	Description</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="NVQLevel">
      <Query>
        <DataSourceName>ADB_HCUKReports</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Faculty">
            <Value>=Parameters!Faculty.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Team">
            <Value>=Parameters!Team.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear VARCHAR(5) = '22/23'
DECLARE @Faculty VARCHAR(50) = 'ALL'
DECLARE @Team VARCHAR(50) = 'ALL'
*/

SELECT
	Code = 'ALL',
	Description = '-- All NVQ Levels --',
	SortOrder = -99

UNION ALL

SELECT DISTINCT
	Code = COALESCE ( AIM.NVQLevelID_v2, 'X' ),
	Description = 
		CASE
			WHEN COALESCE ( AIM.NVQLevelID_v2, 'X' ) = 'E' THEN 'Entry Level'
			ELSE 'Level ' + COALESCE ( AIM.NVQLevelID_v2, 'X' )
		END,
	SortOrder = 
		CASE
			WHEN COALESCE ( AIM.NVQLevelID_v2, 'X' ) = 'E' THEN 0
			WHEN COALESCE ( AIM.NVQLevelID_v2, 'X' ) = 'X' THEN -1
			ELSE TRY_CAST ( AIM.NVQLevelID_v2 AS INT )
		END
FROM ProSolution.dbo.StudentDetail SD
INNER JOIN ProSolution.dbo.Enrolment ENR
	ON ENR.StudentDetailID = SD.StudentDetailID
INNER JOIN ProSolution.dbo.Offering CRS
	ON CRS.OfferingID = ENR.OfferingID
INNER JOIN ProSolution.dbo.CollegeLevel TEAM
	ON TEAM.SID = CRS.SID
INNER JOIN ProSolution.dbo.CollegeLevel FAC
	ON FAC.SID = TEAM.ParentSID
LEFT JOIN ProSolution.dbo.Learning_Aim AIM
	ON AIM.LEARNING_AIM_REF = CRS.QualID
WHERE
	CRS.AcademicYearID = @AcademicYear
	AND ENR.CompletionStatusID IN ( '1', '2', '3' )
	AND ( RTRIM ( FAC.Code ) IN ( @Faculty ) OR 'ALL' IN ( @Faculty ) )
	AND ( RTRIM ( TEAM.Code ) IN ( @Team ) OR 'ALL' IN ( @Team ) )

ORDER BY
	SortOrder</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SortOrder">
          <DataField>SortOrder</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="FundingModel">
      <Query>
        <DataSourceName>ADB_HCUKReports</DataSourceName>
        <CommandText>SELECT
	Code = 'ALL',
	Description = '-- All Fund Models --'
UNION ALL
SELECT
	Code = '14-15',
	Description = '14-15 Funded Students'
UNION ALL
SELECT
	Code = '16-19',
	Description = '16-19 Students (inc. High Needs)'
UNION ALL
SELECT
	Code = 'TLevel',
	Description = 'T Level'
UNION ALL
SELECT
	Code = 'AdvLoan',
	Description = 'Adv Learner Loan'
UNION ALL
SELECT
	Code = 'App',
	Description = 'Apprenticeship'
UNION ALL
SELECT
	Code = 'AEB-ESFA',
	Description = 'AEB Adult - ESFA'
UNION ALL
SELECT
	Code = 'AEB-Dev',
	Description = 'AEB Adult - Devolved'
UNION ALL
SELECT
	Code = 'HE-HEFCE',
	Description = 'HE - HEFCE'
UNION ALL
SELECT
	Code = 'HE-Fran',
	Description = 'HE - Franchised'
UNION ALL
SELECT
	Code = 'HE-Other',
	Description = 'HE - Non-Prescribed'
UNION ALL
SELECT
	Code = 'ComLearn',
	Description = 'Community Learning'
UNION ALL
SELECT
	Code = 'SchoolLinks',
	Description = 'School Links'
UNION ALL
SELECT
	Code = 'NoFund',
	Description = 'Not Funded'</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="OfferingType">
      <Query>
        <DataSourceName>ADB_HCUKReports</DataSourceName>
        <CommandText>SELECT
	Code = CRST.OfferingTypeID,
	Description = CRST.Description
FROM ProSolution.dbo.OfferingType CRST

ORDER BY
	CRST.Description</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EnrolmentType">
      <Query>
        <DataSourceName>ADB_HCUKReports</DataSourceName>
        <CommandText>SELECT
	Code = 0,
	Description = '-- All Enrolment Types --'

UNION ALL

SELECT
	Code = ENRT.EnrolmentTypeID,
	Description = ENRT.Description
FROM ProSolution.dbo.EnrolmentType ENRT

ORDER BY
	Description</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="AgeGroup">
      <Query>
        <DataSourceName>ADB_HCUKReports</DataSourceName>
        <CommandText>SELECT
	Code = 'ALL',
	Description = '-- All Ages --'
UNION ALL
SELECT
	Code = '14-15',
	Description = 'Aged 14-15'
UNION ALL
SELECT
	Code = '16-18',
	Description = 'Aged 16-18'
UNION ALL
SELECT
	Code = '19-24',
	Description = 'Aged 19-24'
UNION ALL
SELECT
	Code = '25+',
	Description = 'Aged 25 and Above'

ORDER BY
	Description</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
