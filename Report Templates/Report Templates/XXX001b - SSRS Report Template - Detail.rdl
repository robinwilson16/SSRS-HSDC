      <am:Version>18.4.11605.240</am:Version>
    </am:UpdatedBy>
    <am:LastModifiedTimestamp>2026-03-13T14:42:29.8856874Z</am:LastModifiedTimestamp>
  </am:AuthoringMetadata>
  <Author>Inspire Education Group</Author>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="EBSReporting">
      <DataSourceReference>EBSReporting</DataSourceReference>
      <rd:SecurityType>Windows</rd:SecurityType>
      <rd:DataSourceID>1b82cd94-8454-486e-89d5-52e7b263a15d</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="APP001">
      <Query>
        <DataSourceName>EBSReporting</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OverdueOnly">
            <Value>=Parameters!OverdueOnly.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Standard">
            <Value>=Parameters!Standard.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OverdueAmount">
            <Value>=Parameters!OverdueAmount.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TrainingConsultant1">
            <Value>=Parameters!TrainingConsultant1.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear VARCHAR(5) = '25/26'
DECLARE @OverdueOnly INT = -1
DECLARE @Standard VARCHAR(3) = 'ALL'
DECLARE @OverdueAmount INT = -1
DECLARE @TrainingConsultant1 VARCHAR(50) = 'ALL'
*/

SELECT
	ENR.AcademicYearID,
	ENR.LearnRefNumber,
	ENR.Surname,
	ENR.Forename,
	ENR.StandardCode,
	ENR.StandardName,
	ENR.CourseCode,
	ENR.CourseTitle,
	ENR.OccurrenceCode,
	ENR.CompletionStatusCode,
	ENR.CompletionStatusName,
	ENR.OutcomeCode,
	ENR.OutcomeName,
	ENR.OriginalStartDate,
	ENR.StartDate,
	ENR.PlannedEndDate,
	ENR.ActualEndDate,
	ENR.AchievementDate,
	TrainingConsultant1StaffRef = COALESCE ( ENR.TrainingConsultant1StaffRef, '0' ),
	TrainingConsultant1StaffName = COALESCE ( ENR.TrainingConsultant1StaffName, '-- Not Specified --' ),
	TrainingConsultant2StaffRef = COALESCE ( ENR.TrainingConsultant2StaffRef, '0' ),
	TrainingConsultant2StaffName = COALESCE ( ENR.TrainingConsultant2StaffName, '-- Not Specified --' ),
	BusinessDevelopmentStaffRef = COALESCE ( ENR.BusinessDevelopmentStaffRef, '0' ),
	BusinessDevelopmentStaffName = COALESCE ( ENR.BusinessDevelopmentStaffName, '-- Not Specified --' ),
	OverdueCategory = 
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 'Completed'
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 'In Gateway'
			WHEN ENR.CompletionStatusCode = '3' THEN 'Withdrawn'
			WHEN ENR.CompletionStatusCode = '6' THEN 'Break in Learning'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN 'Overdue'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN 'Overdue'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN 'Overdue'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN 'Overdue'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN 'Overdue'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN 'Ending Soon'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN 'Ending Soon'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN 'Ending Soon'
			ELSE 'Not Overdue'
		END,
	OverdueCategoryOrder = 
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 7
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 6
			WHEN ENR.CompletionStatusCode = '3' THEN 1
			WHEN ENR.CompletionStatusCode = '6' THEN 2
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN 5
			ELSE 3
		END,
	OverdueAmount = 
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 'Completed'
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 'In Gateway'
			WHEN ENR.CompletionStatusCode = '3' THEN 'Withdrawn'
			WHEN ENR.CompletionStatusCode = '6' THEN 'Break in Learning'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN '180+ Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN '90-179 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN '60-89 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN '30-59 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN '1-29 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN '1-29 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN '30-59 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN '60-89 Days'
			ELSE 'Not Overdue'
		END,
	OverdueAmountOrder = 
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 13
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 12
			WHEN ENR.CompletionStatusCode = '3' THEN 1
			WHEN ENR.CompletionStatusCode = '6' THEN 2
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN 8
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN 7
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN 6
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN 11
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN 10
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN 9
			ELSE 3
		END
FROM Enrolment ENR
INNER JOIN (
	SELECT
		ENR.EnrolmentID,
		ENR.LearnRefNumber,
		ENR.StandardCode,
		ENR.CompletionStatusCode,
		StartDate = COALESCE ( ENR.OriginalStartDate, ENR.StartDate ),
		RowNum = 
			ROW_NUMBER () OVER (
				PARTITION BY
					ENR.LearnRefNumber,
					ENR.StandardCode,
					COALESCE ( ENR.OriginalStartDate, ENR.StartDate )
				ORDER BY
					ENR.CompletionStatusCode,
					ENR.StartDate DESC
			)
	FROM Enrolment ENR
	WHERE
		ENR.AcademicYearID = @AcademicYear
	AND ENR.IncludeInILR = 'Y'
	AND (
		ENR.FundStream = '36'
		OR (
			ENR.FundStream = '35'
			AND ENR.ProgTypeID IS NOT NULL
		)
	)
	AND ENR.LearningAimCode = 'ZPROG001'
) ACT
	ON ACT.LearnRefNumber = ENR.LearnRefNumber
	AND ACT.EnrolmentID = ENR.EnrolmentID
	AND ACT.RowNum = 1

WHERE
	ENR.AcademicYearID = @AcademicYear
	AND ENR.IncludeInILR = 'Y'
	AND (
		ENR.CountAsStart = 'Y'
		OR ENR.CompletionStatusCode = '6'
	)
	AND (
		ENR.FundStream = '36'
		OR (
			ENR.FundStream = '35'
			AND ENR.ProgTypeID IS NOT NULL
		)
	)
	AND ENR.LearningAimCode = 'ZPROG001'
	AND (
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 7
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 6
			WHEN ENR.CompletionStatusCode = '3' THEN 1
			WHEN ENR.CompletionStatusCode = '6' THEN 2
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN 5
			ELSE 3
		END IN ( @OverdueOnly )
		OR -1 IN ( @OverdueOnly )
	)
	AND ( ENR.StandardCode IN ( @Standard ) OR 'ALL' IN ( @Standard ) )
	AND (
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 13
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 12
			WHEN ENR.CompletionStatusCode = '3' THEN 1
			WHEN ENR.CompletionStatusCode = '6' THEN 2
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN 8
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN 7
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN 6
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN 11
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN 10
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN 9
			ELSE 3
		END IN ( @OverdueAmount ) OR -1 IN ( @OverdueAmount )
	)
	AND ( COALESCE ( ENR.TrainingConsultant1StaffRef, '0' ) IN ( @TrainingConsultant1 ) OR 'ALL' IN ( @TrainingConsultant1 ) )
	--AND ENR.LearnRefNumber = '111217'
ORDER BY
	ENR.AcademicYearID,
	ENR.Surname,
	ENR.Forename,
	ENR.LearnRefNumber,
	ENR.CourseCode,
	ENR.StandardCode</CommandText>
      </Query>
      <Fields>
        <Field Name="AcademicYearID">
          <DataField>AcademicYearID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LearnRefNumber">
          <DataField>LearnRefNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Surname">
          <DataField>Surname</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Forename">
          <DataField>Forename</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="StandardCode">
          <DataField>StandardCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="StandardName">
          <DataField>StandardName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CourseCode">
          <DataField>CourseCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CourseTitle">
          <DataField>CourseTitle</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OccurrenceCode">
          <DataField>OccurrenceCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CompletionStatusCode">
          <DataField>CompletionStatusCode</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CompletionStatusName">
          <DataField>CompletionStatusName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OutcomeCode">
          <DataField>OutcomeCode</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="OutcomeName">
          <DataField>OutcomeName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OriginalStartDate">
          <DataField>OriginalStartDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="StartDate">
          <DataField>StartDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="PlannedEndDate">
          <DataField>PlannedEndDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="ActualEndDate">
          <DataField>ActualEndDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="AchievementDate">
          <DataField>AchievementDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="TrainingConsultant1StaffRef">
          <DataField>TrainingConsultant1StaffRef</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TrainingConsultant1StaffName">
          <DataField>TrainingConsultant1StaffName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TrainingConsultant2StaffRef">
          <DataField>TrainingConsultant2StaffRef</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TrainingConsultant2StaffName">
          <DataField>TrainingConsultant2StaffName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BusinessDevelopmentStaffRef">
          <DataField>BusinessDevelopmentStaffRef</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BusinessDevelopmentStaffName">
          <DataField>BusinessDevelopmentStaffName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OverdueCategory">
          <DataField>OverdueCategory</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OverdueCategoryOrder">
          <DataField>OverdueCategoryOrder</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="OverdueAmount">
          <DataField>OverdueAmount</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OverdueAmountOrder">
          <DataField>OverdueAmountOrder</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="AcademicYear">
      <Query>
        <DataSourceName>EBSReporting</DataSourceName>
        <CommandText>SELECT DISTINCT
	Code = ENR.AcademicYearID,
	Description = ENR.AcademicYearID
FROM dbo.Enrolment ENR
ORDER BY
	ENR.AcademicYearID</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="AcademicYearCur">
      <Query>
        <DataSourceName>EBSReporting</DataSourceName>
        <CommandText>SELECT DISTINCT
	Code = ENR.AcademicYearID,
	Description = ENR.AcademicYearID
FROM dbo.Enrolment ENR
WHERE
	ENR.AcademicYearID =
		CASE
			WHEN MONTH ( GETDATE() ) &gt;= 8 THEN RIGHT ( CAST ( YEAR ( GETDATE() ) AS VARCHAR(4) ), 2 ) + '/' + RIGHT ( CAST ( YEAR ( GETDATE() ) + 1 AS VARCHAR(4) ), 2 )
			ELSE RIGHT ( CAST ( YEAR ( GETDATE() ) - 1 AS VARCHAR(4) ), 2 ) + '/' + RIGHT ( CAST ( YEAR ( GETDATE() ) AS VARCHAR(4) ), 2 )
		END
ORDER BY
	ENR.AcademicYearID</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="OverdueAmount">
      <Query>
        <DataSourceName>EBSReporting</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OverdueOnly">
            <Value>=Parameters!OverdueOnly.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Standard">
            <Value>=Parameters!Standard.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear VARCHAR(5) = '25/26'
DECLARE @OverdueOnly INT = -1
DECLARE @Standard VARCHAR(3) = 'ALL'
*/

SELECT
	Code = -1,
	Description  = '-- All Records --'

UNION ALL

SELECT DISTINCT
	Code = 
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 13
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 12
			WHEN ENR.CompletionStatusCode = '3' THEN 1
			WHEN ENR.CompletionStatusCode = '6' THEN 2
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN 8
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN 7
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN 6
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN 11
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN 10
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN 9
			ELSE 3
		END,
	Description = 
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 'Completed'
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 'In Gateway'
			WHEN ENR.CompletionStatusCode = '3' THEN 'Withdrawn'
			WHEN ENR.CompletionStatusCode = '6' THEN 'Break in Learning'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN '180+ Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN '90-179 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN '60-89 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN '30-59 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN '1-29 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN '1-29 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN '30-59 Days'
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN '60-89 Days'
			ELSE 'Not Overdue'
		END
FROM Enrolment ENR
INNER JOIN (
	SELECT
		ENR.EnrolmentID,
		ENR.LearnRefNumber,
		ENR.StandardCode,
		ENR.CompletionStatusCode,
		StartDate = COALESCE ( ENR.OriginalStartDate, ENR.StartDate ),
		RowNum = 
			ROW_NUMBER () OVER (
				PARTITION BY
					ENR.LearnRefNumber,
					ENR.StandardCode,
					COALESCE ( ENR.OriginalStartDate, ENR.StartDate )
				ORDER BY
					ENR.CompletionStatusCode,
					ENR.StartDate DESC
			)
	FROM Enrolment ENR
	WHERE
		ENR.AcademicYearID = @AcademicYear
	AND ENR.IncludeInILR = 'Y'
	AND (
		ENR.FundStream = '36'
		OR (
			ENR.FundStream = '35'
			AND ENR.ProgTypeID IS NOT NULL
		)
	)
	AND ENR.LearningAimCode = 'ZPROG001'
) ACT
	ON ACT.LearnRefNumber = ENR.LearnRefNumber
	AND ACT.EnrolmentID = ENR.EnrolmentID
	AND ACT.RowNum = 1

WHERE
	ENR.AcademicYearID = @AcademicYear
	AND ENR.IncludeInILR = 'Y'
	AND (
		ENR.CountAsStart = 'Y'
		OR ENR.CompletionStatusCode = '6'
	)
	AND (
		ENR.FundStream = '36'
		OR (
			ENR.FundStream = '35'
			AND ENR.ProgTypeID IS NOT NULL
		)
	)
	AND ENR.LearningAimCode = 'ZPROG001'
	AND (
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 7
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 6
			WHEN ENR.CompletionStatusCode = '3' THEN 1
			WHEN ENR.CompletionStatusCode = '6' THEN 2
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN 5
			ELSE 3
		END IN ( @OverdueOnly )
		OR -1 IN ( @OverdueOnly )
	)
	AND ( ENR.StandardCode IN ( @Standard ) OR 'ALL' IN ( @Standard ) )

ORDER BY
	Code</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Standard">
      <Query>
        <DataSourceName>EBSReporting</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OverdueOnly">
            <Value>=Parameters!OverdueOnly.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear VARCHAR(5) = '25/26'
DECLARE @OverdueOnly INT = -1
*/


SELECT
	Code = 'ALL',
	Description = '-- All Standards --'

UNION ALL

SELECT DISTINCT
	Code = ENR.StandardCode,
	Description = ENR.StandardName + ' (' + ENR.StandardCode + ')'
FROM Enrolment ENR
INNER JOIN (
	SELECT
		ENR.EnrolmentID,
		ENR.LearnRefNumber,
		ENR.StandardCode,
		ENR.CompletionStatusCode,
		StartDate = COALESCE ( ENR.OriginalStartDate, ENR.StartDate ),
		RowNum = 
			ROW_NUMBER () OVER (
				PARTITION BY
					ENR.LearnRefNumber,
					ENR.StandardCode,
					COALESCE ( ENR.OriginalStartDate, ENR.StartDate )
				ORDER BY
					ENR.CompletionStatusCode,
					ENR.StartDate DESC
			)
	FROM Enrolment ENR
	WHERE
		ENR.AcademicYearID = @AcademicYear
	AND ENR.IncludeInILR = 'Y'
	AND (
		ENR.FundStream = '36'
		OR (
			ENR.FundStream = '35'
			AND ENR.ProgTypeID IS NOT NULL
		)
	)
	AND ENR.LearningAimCode = 'ZPROG001'
) ACT
	ON ACT.LearnRefNumber = ENR.LearnRefNumber
	AND ACT.EnrolmentID = ENR.EnrolmentID
	AND ACT.RowNum = 1

WHERE
	ENR.AcademicYearID = @AcademicYear
	AND ENR.IncludeInILR = 'Y'
	AND (
		ENR.CountAsStart = 'Y'
		OR ENR.CompletionStatusCode = '6'
	)
	AND (
		ENR.FundStream = '36'
		OR (
			ENR.FundStream = '35'
			AND ENR.ProgTypeID IS NOT NULL
		)
	)
	AND ENR.LearningAimCode = 'ZPROG001'
	AND (
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 7
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 6
			WHEN ENR.CompletionStatusCode = '3' THEN 1
			WHEN ENR.CompletionStatusCode = '6' THEN 2
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN 5
			ELSE 3
		END IN ( @OverdueOnly )
		OR -1 IN ( @OverdueOnly )
	)

ORDER BY
	Description</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="OverdueOnly">
      <Query>
        <DataSourceName>EBSReporting</DataSourceName>
        <CommandText>SELECT
	Code = -1,
	Dexcription = '-- All Records --'

UNION ALL

SELECT
	Code = 1,
	Dexcription = 'Withdrawn'

UNION ALL

SELECT
	Code = 2,
	Dexcription = 'Break in Learning'

UNION ALL

SELECT
	Code = 3,
	Dexcription = 'Not Overdue'

UNION ALL

SELECT
	Code = 4,
	Dexcription = 'Overdue'

UNION ALL

SELECT
	Code = 5,
	Dexcription = 'Ending Soon'

UNION ALL

SELECT
	Code = 6,
	Dexcription = 'In Gateway'

UNION ALL

SELECT
	Code = 7,
	Dexcription = 'Completed'</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Dexcription">
          <DataField>Dexcription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TrainingConsultant">
      <Query>
        <DataSourceName>EBSReporting</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OverdueOnly">
            <Value>=Parameters!OverdueOnly.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Standard">
            <Value>=Parameters!Standard.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OverdueAmount">
            <Value>=Parameters!OverdueAmount.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear VARCHAR(5) = '25/26'
DECLARE @OverdueOnly INT = -1
DECLARE @Standard VARCHAR(3) = 'ALL'
DECLARE @OverdueAmount INT = -1
*/

SELECT
	Code = 'ALL',
	Description = '-- All Training Consultants --'

UNION ALL

SELECT DISTINCT
	Code = COALESCE ( ENR.TrainingConsultant1StaffRef, '0' ),
	Description = COALESCE ( ENR.TrainingConsultant1StaffName, '-- No Training Consultant Specified --' )
FROM Enrolment ENR
INNER JOIN (
	SELECT
		ENR.EnrolmentID,
		ENR.LearnRefNumber,
		ENR.StandardCode,
		ENR.CompletionStatusCode,
		StartDate = COALESCE ( ENR.OriginalStartDate, ENR.StartDate ),
		RowNum = 
			ROW_NUMBER () OVER (
				PARTITION BY
					ENR.LearnRefNumber,
					ENR.StandardCode,
					COALESCE ( ENR.OriginalStartDate, ENR.StartDate )
				ORDER BY
					ENR.CompletionStatusCode,
					ENR.StartDate DESC
			)
	FROM Enrolment ENR
	WHERE
		ENR.AcademicYearID = @AcademicYear
	AND ENR.IncludeInILR = 'Y'
	AND (
		ENR.FundStream = '36'
		OR (
			ENR.FundStream = '35'
			AND ENR.ProgTypeID IS NOT NULL
		)
	)
	AND ENR.LearningAimCode = 'ZPROG001'
) ACT
	ON ACT.LearnRefNumber = ENR.LearnRefNumber
	AND ACT.EnrolmentID = ENR.EnrolmentID
	AND ACT.RowNum = 1

WHERE
	ENR.AcademicYearID = @AcademicYear
	AND ENR.IncludeInILR = 'Y'
	AND (
		ENR.CountAsStart = 'Y'
		OR ENR.CompletionStatusCode = '6'
	)
	AND (
		ENR.FundStream = '36'
		OR (
			ENR.FundStream = '35'
			AND ENR.ProgTypeID IS NOT NULL
		)
	)
	AND ENR.LearningAimCode = 'ZPROG001'
	AND (
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 7
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 6
			WHEN ENR.CompletionStatusCode = '3' THEN 1
			WHEN ENR.CompletionStatusCode = '6' THEN 2
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN 5
			ELSE 3
		END IN ( @OverdueOnly )
		OR -1 IN ( @OverdueOnly )
	)
	AND ( ENR.StandardCode IN ( @Standard ) OR 'ALL' IN ( @Standard ) )
	AND (
		CASE
			WHEN ENR.CompletionStatusCode = '2' THEN 13
			WHEN
				ENR.CompletionStatusCode = '1'
				AND COALESCE ( ENR.OutcomeCode, '9' ) = '8' THEN 12
			WHEN ENR.CompletionStatusCode = '3' THEN 1
			WHEN ENR.CompletionStatusCode = '6' THEN 2
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 180, ENR.PlannedEndDate ) AS DATE ) THEN 8
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 90, ENR.PlannedEndDate ) AS DATE ) THEN 7
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 60, ENR.PlannedEndDate ) AS DATE ) THEN 6
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt;= CAST ( DATEADD ( DAY, 30, ENR.PlannedEndDate ) AS DATE ) THEN 5
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, 0, ENR.PlannedEndDate ) AS DATE ) THEN 4
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -30, ENR.PlannedEndDate ) AS DATE ) THEN 11
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -60, ENR.PlannedEndDate ) AS DATE ) THEN 10
			WHEN CAST ( COALESCE ( ENR.ActualEndDate, GETDATE() ) AS DATE ) &gt; CAST ( DATEADD ( DAY, -90, ENR.PlannedEndDate ) AS DATE ) THEN 9
			ELSE 3
		END IN ( @OverdueAmount ) OR -1 IN ( @OverdueAmount )
	)

ORDER BY
	Description</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
