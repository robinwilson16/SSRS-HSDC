  <DataSets>
    <DataSet Name="SCA001">
      <Query>
        <DataSourceName>ProSolution</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ILRReturn">
            <Value>=Parameters!ILRReturn.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear VARCHAR(5) = '25/26'
DECLARE @ILRReturn VARCHAR(3) = 'R07'
*/


DECLARE @LastYear VARCHAR(5) = CAST ( CAST ( LEFT ( @AcademicYear, 2 ) AS INT ) - 1 AS VARCHAR(2) ) + '/' + CAST ( CAST ( RIGHT ( @AcademicYear, 2 ) AS INT ) - 1 AS VARCHAR(2) )


--Attendance
--Register Session Dates - Planned and Ad-Hoc
DROP TABLE IF EXISTS #RegisterSessionDates
SELECT
	REG.RegisterID,
	RSES.RegisterSessionID,
	RSES.Date,
	RSES.StartTime,
	RSES.EndTime,
	RSES.Duration
	INTO #RegisterSessionDates
FROM ProSolution.dbo.Register REG
INNER JOIN ProSolution.dbo.RegisterSession RSES
	ON RSES.RegisterID = REG.RegisterID
WHERE
	REG.AcademicYearID = @AcademicYear
UNION

SELECT
	REGSC.RegisterID,
	RegisterSessionID = 0 - REGSC.RegisterScheduleID,
	REGSC.Date,
	REGSC.StartTime,
	REGSC.EndTime,
	REGSC.Duration
FROM ProSolution.dbo.Register REG
INNER JOIN ProSolution.dbo.RegisterSchedule REGSC
	ON REGSC.RegisterID = REG.RegisterID
WHERE
	REG.AcademicYearID = @AcademicYear



--Register Sessions - Planned and Ad-Hoc
DROP TABLE IF EXISTS #RegisterSession
SELECT
	RSES.RegisterID,
	RegisterSessionID = MAX ( RSES.RegisterSessionID ),
	SessionNo = 
		ROW_NUMBER () OVER (
			PARTITION BY
				RSES.RegisterID
			ORDER BY
				RSES.Date,
				RSES.StartTime
		),
	RSES.Date,
	RSES.StartTime,
	EndTime = MAX ( RSES.EndTime ),
	Duration = MAX ( RSES.Duration )
	INTO #RegisterSession
FROM #RegisterSessionDates RSES
--WHERE
--	RSES.RegisterID = 199179
GROUP BY
	RSES.RegisterID,
	RSES.Date,
	RSES.StartTime
--ORDER BY
--	RSES.Date

ALTER TABLE #RegisterSession
ALTER COLUMN RegisterID INT NOT NULL
ALTER TABLE #RegisterSession
ALTER COLUMN RegisterSessionID INT NOT NULL
ALTER TABLE #RegisterSession
ALTER COLUMN SessionNo INT NOT NULL
ALTER TABLE #RegisterSession
ADD PRIMARY KEY (RegisterID, RegisterSessionID, SessionNo);



--Attendance (Change Columns As Needed)
DROP TABLE IF EXISTS #AttendData
SELECT
	AcademicYearID = SD.AcademicYearID,
	StudentDetailID = SD.StudentDetailID,
	StudentRef = RTRIM ( SD.RefNo ),
	CourseCode = CRS.Code,
	IsLast4Weeks = 
		CASE
			WHEN CAST ( RSES.Date AS DATE ) &gt;= CAST ( DATEADD ( DAY, -28, GETDATE() ) AS DATE )
			AND CAST ( RSES.Date AS DATE ) &lt;= CAST ( GETDATE() AS DATE )
			THEN 'Y'
			ELSE 'N'
		END,
	LessonID = RSES.RegisterSessionID,
	IsLessonToDate = CASE WHEN CAST ( RSES.Date AS DATE ) &lt;= CAST ( GETDATE() AS DATE ) THEN 'Y' ELSE 'N' END,
	SlotID = RSES.RegisterSessionID,
	Marked = CASE WHEN RM.MarkTypeID IS NOT NULL AND CAST ( RSES.Date AS DATE ) &lt;= CAST ( GETDATE() AS DATE ) THEN 1 ELSE 0 END,
	Unmarked = CASE WHEN RM.MarkTypeID IS NULL AND CAST ( RSES.Date AS DATE ) &lt;= CAST ( GETDATE() AS DATE ) THEN 1 ELSE 0 END,
	--Change to COALESCE ( MTS.MarkTypeStatusID, 0 ) to count missing marks as possible
	Possible = CASE WHEN COALESCE ( MTS.MarkTypeStatusID, 2 ) &lt;&gt; 2 AND CAST ( RSES.Date AS DATE ) &lt;= CAST ( GETDATE() AS DATE ) THEN 1 ELSE 0 END,
	Present = CASE WHEN MTS.MarkTypeStatusID = 1 THEN 1 ELSE 0 END,
	Absent = CASE WHEN MTS.MarkTypeStatusID = 0 THEN 1 ELSE 0 END,
	Neutral = CASE WHEN MTS.MarkTypeStatusID = 2 THEN 1 ELSE 0 END,
	--NeutralNonDefault = SUM ( CASE WHEN MTS.MarkTypeStatusID = 2 AND DEF.DefaultNeutralMark IS NULL THEN 1 ELSE 0 END ),
	AuthAbsence = CASE WHEN MT.IsAuthorisedAbsence = 1 THEN 1 ELSE 0 END,
	Late = CASE WHEN MT.IsLate = 1 THEN 1 ELSE 0 END
	INTO #AttendData
FROM ProSolution.dbo.StudentDetail SD
INNER JOIN ProSolution.dbo.Enrolment ENR
	ON ENR.StudentDetailID = SD.StudentDetailID
INNER JOIN ProSolution.dbo.Offering CRS
	ON CRS.OfferingID = ENR.OfferingID
INNER JOIN ProSolution.dbo.RegisterStudent REGS
	ON REGS.EnrolmentID = ENR.EnrolmentID
INNER JOIN ProSolution.dbo.Register REG
	ON REG.RegisterID = REGS.RegisterID
INNER JOIN #RegisterSession RSES
	ON RSES.RegisterID = REG.RegisterID
LEFT JOIN ProSolution.dbo.RegisterMark AS RM 
	ON RM.RegisterSessionID = RSES.RegisterSessionID
	AND RM.RegisterStudentID = REGS.RegisterStudentID
LEFT JOIN ProSolution.dbo.MarkType AS MT 
	ON MT.MarkTypeID = RM.MarkTypeID
LEFT JOIN ProSolution.dbo.MarkTypeStatus MTS
	ON MTS.MarkTypeStatusID = MT.MarkTypeStatusID
LEFT JOIN ProSolution.dbo.Learning_Aim AIM
	ON AIM.LEARNING_AIM_REF = CRS.QualID
--LEFT JOIN (
--	SELECT DISTINCT
--		DefaultNeutralMark = ST.Setting
--	FROM SystemSetting ST
--	WHERE
--		ST.Code IN ( 
--			'TransferredMark',
--			'WithdrawnMark',
--			'TempWithdrawnMark',
--			'BackFillMark',
--			'BackFillMarkAfterStart'
--		)
--		AND ST.Setting IS NOT NULL
--) DEF
--	ON DEF.DefaultNeutralMark = MT.Mark
WHERE
	SD.AcademicYearID = @AcademicYear
--ORDER BY
--	SD.AcademicYearID,
--	CRS.Code


--Attendance
DROP TABLE IF EXISTS #Attend
SELECT
	ATT.AcademicYearID,
	ATT.StudentDetailID,
	ATT.StudentRef,
	Possible = SUM ( ATT.Possible ),
	Present = SUM ( ATT.Present )
	INTO #Attend
FROM #AttendData ATT
GROUP BY
	ATT.AcademicYearID,
	ATT.StudentDetailID,
	ATT.StudentRef



--Non-Attendance By Learner
DROP TABLE IF EXISTS #NonAttendData
SELECT
	ATT.StudentDetailID,
	ATT.StudentRef,
	Is4WeekNonAttend = 
		CASE 
			WHEN 
				SUM ( ATT.Absent ) &gt; 0
				AND SUM ( ATT.Present ) = 0
				THEN 'Y'
			ELSE 'N'
		END
	INTO #NonAttendData
FROM #AttendData ATT
WHERE
	ATT.IsLast4Weeks = 'Y'
GROUP BY
	ATT.StudentDetailID,
	ATT.StudentRef


--Non Attenders
DROP TABLE IF EXISTS #NonAttend
SELECT
	ATT.StudentDetailID,
	ATT.StudentRef
	INTO #NonAttend
FROM #NonAttendData ATT
WHERE
	ATT.Is4WeekNonAttend = 'Y'



--High Risk (from ProMonitor)
DROP TABLE IF EXISTS #AtRisk
SELECT
	StudentRef = S.StudentID,
	StudentRiskCode = S.LearnerStatus,
	StudentRiskName = STA.LearnerStatus
	INTO #AtRisk
FROM [DBS-MIS-02\advanced].ProMonitor.dbo.Student S
INNER JOIN [DBS-MIS-02\advanced].ProMonitor.dbo.LearnerInformation_LearnerStatus STA
	ON STA.LearnerStatusID = S.LearnerStatus
WHERE
	S.AcademicYearID = @AcademicYear
	AND S.LearnerStatus = 1



--Retention and Achievement
DROP TABLE IF EXISTS #RetAch
SELECT
	PA.EndYear,
	Category = 'ALL',
	RetInYrPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsStart ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsRetInYr ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsStart ) AS FLOAT )
			END,
			3
		),
	RetPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsLeaver ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsComp ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsLeaver ) AS FLOAT )
			END,
			3
		),
	AchPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsLeaver ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAch ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsLeaver ) AS FLOAT )
			END,
			3
		),
	PassPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsComp ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAch ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsComp ) AS FLOAT )
			END,
			3
		),
	PassBestCasePer = 
		ROUND ( 
			CASE
				WHEN SUM ( CASE WHEN PA.IsWdr = 0 AND PA.IsPlannedBreak = 0 AND PA.IsLeaverBestCase = 1 THEN 1 ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAchBestCase ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN PA.IsWdr = 0 AND PA.IsPlannedBreak = 0 AND PA.IsLeaverBestCase = 1 THEN 1 ELSE 0 END ) AS FLOAT )
			END,
			3
		)
	INTO #RetAch
FROM [DBS-MIS-02\advanced].ProAchieveSummariser.dbo.PRA_ProAchieveSummaryData PA
WHERE
	PA.EndYear &gt;= @LastYear
	AND PA.EndYear &lt;= @AcademicYear
	AND PA.ProvisionType = 'CL'
	AND PA.SummaryType = 'Overall'
	AND PA.IsDefaultSummary = 1
GROUP BY
	PA.EndYear

UNION ALL

SELECT
	PA.EndYear,
	Category = '1618',
	RetInYrPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsStart ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsRetInYr ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsStart ) AS FLOAT )
			END,
			3
		),
	RetPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsLeaver ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsComp ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsLeaver ) AS FLOAT )
			END,
			3
		),
	AchPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsLeaver ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAch ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsLeaver ) AS FLOAT )
			END,
			3
		),
	PassPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsComp ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAch ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsComp ) AS FLOAT )
			END,
			3
		),
	PassBestCasePer = 
		ROUND ( 
			CASE
				WHEN SUM ( CASE WHEN PA.IsWdr = 0 AND PA.IsPlannedBreak = 0 AND PA.IsLeaverBestCase = 1 THEN 1 ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAchBestCase ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN PA.IsWdr = 0 AND PA.IsPlannedBreak = 0 AND PA.IsLeaverBestCase = 1 THEN 1 ELSE 0 END ) AS FLOAT )
			END,
			3
		)
FROM [DBS-MIS-02\advanced].ProAchieveSummariser.dbo.PRA_ProAchieveSummaryData PA
WHERE
	PA.EndYear &gt;= @LastYear
	AND PA.EndYear &lt;= @AcademicYear
	AND PA.ProvisionType = 'CL'
	AND PA.SummaryType = 'Overall'
	AND PA.IsDefaultSummary = 1
	AND PA.AgeGroup = '16 - 18'
GROUP BY
	PA.EndYear

UNION ALL

SELECT
	PA.EndYear,
	Category = '19+',
	RetInYrPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsStart ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsRetInYr ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsStart ) AS FLOAT )
			END,
			3
		),
	RetPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsLeaver ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsComp ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsLeaver ) AS FLOAT )
			END,
			3
		),
	AchPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsLeaver ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAch ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsLeaver ) AS FLOAT )
			END,
			3
		),
	PassPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsComp ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAch ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsComp ) AS FLOAT )
			END,
			3
		),
	PassBestCasePer = 
		ROUND ( 
			CASE
				WHEN SUM ( CASE WHEN PA.IsWdr = 0 AND PA.IsPlannedBreak = 0 AND PA.IsLeaverBestCase = 1 THEN 1 ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAchBestCase ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN PA.IsWdr = 0 AND PA.IsPlannedBreak = 0 AND PA.IsLeaverBestCase = 1 THEN 1 ELSE 0 END ) AS FLOAT )
			END,
			3
		)
FROM [DBS-MIS-02\advanced].ProAchieveSummariser.dbo.PRA_ProAchieveSummaryData PA
WHERE
	PA.EndYear &gt;= @LastYear
	AND PA.EndYear &lt;= @AcademicYear
	AND PA.ProvisionType = 'CL'
	AND PA.SummaryType = 'Overall'
	AND PA.IsDefaultSummary = 1
	AND PA.AgeGroup = '19 +'
GROUP BY
	PA.EndYear

UNION ALL

SELECT
	PA.EndYear,
	Category = 'GCSE1618',
	RetInYrPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsStart ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsRetInYr ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsStart ) AS FLOAT )
			END,
			3
		),
	RetPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsLeaver ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsComp ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsLeaver ) AS FLOAT )
			END,
			3
		),
	AchPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsLeaver ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAch ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsLeaver ) AS FLOAT )
			END,
			3
		),
	PassPer = 
		ROUND ( 
			CASE
				WHEN SUM ( PA.IsComp ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAch ) AS FLOAT )
					/
					CAST ( SUM ( PA.IsComp ) AS FLOAT )
			END,
			3
		),
	PassBestCasePer = 
		ROUND ( 
			CASE
				WHEN SUM ( CASE WHEN PA.IsWdr = 0 AND PA.IsPlannedBreak = 0 AND PA.IsLeaverBestCase = 1 THEN 1 ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( PA.IsAchBestCase ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN PA.IsWdr = 0 AND PA.IsPlannedBreak = 0 AND PA.IsLeaverBestCase = 1 THEN 1 ELSE 0 END ) AS FLOAT )
			END,
			3
		)
FROM [DBS-MIS-02\advanced].ProAchieveSummariser.dbo.PRA_ProAchieveSummaryData PA
WHERE
	PA.EndYear &gt;= @LastYear
	AND PA.EndYear &lt;= @AcademicYear
	AND PA.ProvisionType = 'CL'
	AND PA.SummaryType = 'Overall'
	AND PA.IsDefaultSummary = 1
	AND PA.LARSAimTypeCode = '0003'
	AND PA.FundStream = '25'
GROUP BY
	PA.EndYear


--FIS
SELECT
	AcademicYear = @AcademicYear,
	LastYear = @LastYear,
	ILRReturn = @ILRReturn,
	ILRReturnDate = MAX ( FD.ILRReturnDate ),
	Category = 'All Learners',
	LastYearAch = RETL.AchPer,
	Target = TAR.Target / 100,
	AttendPer = 
		ROUND ( 
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Possible ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Present ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Possible ELSE 0 END ) AS FLOAT )
			END
		, 3 ),
	CurrentRet = RET.RetInYrPer,
	LastYearRetSamePoint = 
		ROUND (
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallRetainedFunded ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) AS FLOAT )
			END,
			3
		),
	DiffRet = 
		RET.RetInYrPer
		-
		ROUND (
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallRetainedFunded ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) AS FLOAT )
			END,
			3
		),
	NatAvgGFE = TAR.NatTargetGFE / 100,
	NatAvgAll = TAR.NatTargetALL / 100,
	CurrentVolume = COUNT ( DISTINCT CASE WHEN FD.AcademicYear = @AcademicYear THEN FD.LearnRefNumber ELSE NULL END ),
	HighRisk = COUNT ( DISTINCT RSK.StudentRef ),
	NonAttend = COUNT ( DISTINCT NAT.StudentRef ),
	ProjectedPass = RET.PassBestCasePer,
	LastYearFinalVolume = COUNT ( DISTINCT CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = 'R14' THEN FD.LearnRefNumber ELSE NULL END )
FROM FIS_FundingData.dbo.FIS_TeamTargets TAR
LEFT JOIN FIS_FundingData.dbo.FIS_FundingData FD
	ON FD.ProviderNumber = TAR.ProviderNumber
LEFT JOIN #Attend ATT
	ON ATT.StudentRef = FD.LearnRefNumber
LEFT JOIN #NonAttend NAT
	ON NAT.StudentRef = FD.LearnRefNumber
LEFT JOIN #AtRisk RSK
	ON RSK.StudentRef = FD.LearnRefNumber
LEFT JOIN #RetAch RET
	ON RET.EndYear = @LastYear
	AND RET.Category = TAR.Measure
LEFT JOIN #RetAch RETL
	ON RETL.EndYear = @LastYear
	AND RETL.Category = TAR.Measure
WHERE
	FD.AcademicYear &gt;= @LastYear
	AND FD.AcademicYear &lt;= @AcademicYear
	AND (
		FD.ILRReturn = @ILRReturn
		OR (
			FD.AcademicYear = @LastYear
			AND FD.ILRReturn = 'R14'
			AND FD.ILRReturn &lt;&gt; @ILRReturn
		)
	)
	AND FD.IsFinalReturn = 1
	AND FD.IsOverallStart = 1
	AND TAR.Measure = 'ALL'
GROUP BY
	RETL.AchPer,
	TAR.Target,
	RET.RetInYrPer,
	TAR.NatTargetGFE,
	TAR.NatTargetALL,
	RET.PassBestCasePer

UNION ALL

SELECT
	AcademicYear = @AcademicYear,
	LastYear = @LastYear,
	ILRReturn = @ILRReturn,
	ILRReturnDate = MAX ( FD.ILRReturnDate ),
	Category = '16-18 (inc. FS)',
	LastYearAch = RETL.AchPer,
	Target = TAR.Target / 100,
	AttendPer = 
		ROUND ( 
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Possible ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Present ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Possible ELSE 0 END ) AS FLOAT )
			END
		, 3 ),
	CurrentRet = RET.RetInYrPer,
	LastYearRetSamePoint = 
		ROUND (
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallRetainedFunded ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) AS FLOAT )
			END,
			3
		),
	DiffRet = 
		RET.RetInYrPer
		-
		ROUND (
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallRetainedFunded ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) AS FLOAT )
			END,
			3
		),
	NatAvgGFE = TAR.NatTargetGFE / 100,
	NatAvgAll = TAR.NatTargetALL / 100,
	CurrentVolume = COUNT ( DISTINCT CASE WHEN FD.AcademicYear = @AcademicYear THEN FD.LearnRefNumber ELSE NULL END ),
	HighRisk = COUNT ( DISTINCT RSK.StudentRef ),
	NonAttend = COUNT ( DISTINCT NAT.StudentRef ),
	ProjectedPass = RET.PassBestCasePer,
	LastYearFinalVolume = COUNT ( DISTINCT CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = 'R14' THEN FD.LearnRefNumber ELSE NULL END )
FROM FIS_FundingData.dbo.FIS_TeamTargets TAR
LEFT JOIN FIS_FundingData.dbo.FIS_FundingData FD
	ON FD.ProviderNumber = TAR.ProviderNumber
LEFT JOIN #Attend ATT
	ON ATT.StudentRef = FD.LearnRefNumber
LEFT JOIN #NonAttend NAT
	ON NAT.StudentRef = FD.LearnRefNumber
LEFT JOIN #AtRisk RSK
	ON RSK.StudentRef = FD.LearnRefNumber
LEFT JOIN #RetAch RET
	ON RET.EndYear = @LastYear
	AND RET.Category = TAR.Measure
LEFT JOIN #RetAch RETL
	ON RETL.EndYear = @LastYear
	AND RETL.Category = TAR.Measure
WHERE
	FD.AcademicYear &gt;= @LastYear
	AND FD.AcademicYear &lt;= @AcademicYear
	AND (
		FD.ILRReturn = @ILRReturn
		OR (
			FD.AcademicYear = @LastYear
			AND FD.ILRReturn = 'R14'
			AND FD.ILRReturn &lt;&gt; @ILRReturn
		)
	)
	AND FD.IsFinalReturn = 1
	AND FD.IsOverallStart = 1
	AND FD.FundLineCategory = '16-19 Funding'
	AND TAR.Measure = '1618'
GROUP BY
	RETL.AchPer,
	TAR.Target,
	RET.RetInYrPer,
	TAR.NatTargetGFE,
	TAR.NatTargetALL,
	RET.PassBestCasePer

UNION ALL

SELECT
	AcademicYear = @AcademicYear,
	LastYear = @LastYear,
	ILRReturn = @ILRReturn,
	ILRReturnDate = MAX ( FD.ILRReturnDate ),
	Category = '19+ (inc. FS)',
	LastYearAch = RETL.AchPer,
	Target = TAR.Target / 100,
	AttendPer = 
		ROUND ( 
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Possible ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Present ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Possible ELSE 0 END ) AS FLOAT )
			END
		, 3 ),
	CurrentRet = RET.RetInYrPer,
	LastYearRetSamePoint = 
		ROUND (
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallRetainedFunded ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) AS FLOAT )
			END,
			3
		),
	DiffRet = 
		RET.RetInYrPer
		-
		ROUND (
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallRetainedFunded ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) AS FLOAT )
			END,
			3
		),
	NatAvgGFE = TAR.NatTargetGFE / 100,
	NatAvgAll = TAR.NatTargetALL / 100,
	CurrentVolume = COUNT ( DISTINCT CASE WHEN FD.AcademicYear = @AcademicYear THEN FD.LearnRefNumber ELSE NULL END ),
	HighRisk = COUNT ( DISTINCT RSK.StudentRef ),
	NonAttend = COUNT ( DISTINCT NAT.StudentRef ),
	ProjectedPass = RET.PassBestCasePer,
	LastYearFinalVolume = COUNT ( DISTINCT CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = 'R14' THEN FD.LearnRefNumber ELSE NULL END )
FROM FIS_FundingData.dbo.FIS_TeamTargets TAR
LEFT JOIN FIS_FundingData.dbo.FIS_FundingData FD
	ON FD.ProviderNumber = TAR.ProviderNumber
LEFT JOIN #Attend ATT
	ON ATT.StudentRef = FD.LearnRefNumber
LEFT JOIN #NonAttend NAT
	ON NAT.StudentRef = FD.LearnRefNumber
LEFT JOIN #AtRisk RSK
	ON RSK.StudentRef = FD.LearnRefNumber
LEFT JOIN #RetAch RET
	ON RET.EndYear = @LastYear
	AND RET.Category = TAR.Measure
LEFT JOIN #RetAch RETL
	ON RETL.EndYear = @LastYear
	AND RETL.Category = TAR.Measure
WHERE
	FD.AcademicYear &gt;= @LastYear
	AND FD.AcademicYear &lt;= @AcademicYear
	AND (
		FD.ILRReturn = @ILRReturn
		OR (
			FD.AcademicYear = @LastYear
			AND FD.ILRReturn = 'R14'
			AND FD.ILRReturn &lt;&gt; @ILRReturn
		)
	)
	AND FD.IsFinalReturn = 1
	AND FD.IsOverallStart = 1
	AND FD.FundLineCategory IN (
		'Adult Skills Fund',
		'Advanced Learner Loan',
		'Full Cost',
		'Higher Education',
		'Skills Bootcamps'
	)
	AND TAR.Measure = '19+'
GROUP BY
	RETL.AchPer,
	TAR.Target,
	RET.RetInYrPer,
	TAR.NatTargetGFE,
	TAR.NatTargetALL,
	RET.PassBestCasePer

UNION ALL

SELECT
	AcademicYear = @AcademicYear,
	LastYear = @LastYear,
	ILRReturn = @ILRReturn,
	ILRReturnDate = MAX ( FD.ILRReturnDate ),
	Category = 'GCSE - 16-18',
	LastYearAch = RETL.AchPer,
	Target = TAR.Target / 100,
	AttendPer = 
		ROUND ( 
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Possible ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Present ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @AcademicYear THEN ATT.Possible ELSE 0 END ) AS FLOAT )
			END
		, 3 ),
	CurrentRet = RET.RetInYrPer,
	LastYearRetSamePoint = 
		ROUND (
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallRetainedFunded ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) AS FLOAT )
			END,
			3
		),
	DiffRet = 
		RET.RetInYrPer
		-
		ROUND (
			CASE
				WHEN SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) = 0 THEN 0
				ELSE
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallRetainedFunded ELSE 0 END ) AS FLOAT )
					/
					CAST ( SUM ( CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = @ILRReturn THEN FD.IsOverallStart ELSE 0 END ) AS FLOAT )
			END,
			3
		),
	NatAvgGFE = TAR.NatTargetGFE / 100,
	NatAvgAll = TAR.NatTargetALL / 100,
	CurrentVolume = COUNT ( DISTINCT CASE WHEN FD.AcademicYear = @AcademicYear THEN FD.LearnRefNumber ELSE NULL END ),
	HighRisk = COUNT ( DISTINCT RSK.StudentRef ),
	NonAttend = COUNT ( DISTINCT NAT.StudentRef ),
	ProjectedPass = RET.PassBestCasePer,
	LastYearFinalVolume = COUNT ( DISTINCT CASE WHEN FD.AcademicYear = @LastYear AND FD.ILRReturn = 'R14' THEN FD.LearnRefNumber ELSE NULL END )
FROM FIS_FundingData.dbo.FIS_TeamTargets TAR
LEFT JOIN FIS_FundingData.dbo.FIS_FundingData FD
	ON FD.ProviderNumber = TAR.ProviderNumber
LEFT JOIN #Attend ATT
	ON ATT.StudentRef = FD.LearnRefNumber
LEFT JOIN #NonAttend NAT
	ON NAT.StudentRef = FD.LearnRefNumber
LEFT JOIN #AtRisk RSK
	ON RSK.StudentRef = FD.LearnRefNumber
LEFT JOIN #RetAch RET
	ON RET.EndYear = @LastYear
	AND RET.Category = TAR.Measure
LEFT JOIN #RetAch RETL
	ON RETL.EndYear = @LastYear
	AND RETL.Category = TAR.Measure
WHERE
	FD.AcademicYear &gt;= @LastYear
	AND FD.AcademicYear &lt;= @AcademicYear
	AND (
		FD.ILRReturn = @ILRReturn
		OR (
			FD.AcademicYear = @LastYear
			AND FD.ILRReturn = 'R14'
			AND FD.ILRReturn &lt;&gt; @ILRReturn
		)
	)
	AND FD.IsFinalReturn = 1
	AND FD.IsOverallStart = 1
	AND FD.LearningAimTypeCode = '0003'
	AND FD.FundLineCategory = '16-19 Funding'
	AND TAR.Measure = 'GCSE1618'
GROUP BY
	RETL.AchPer,
	TAR.Target,
	RET.RetInYrPer,
	TAR.NatTargetGFE,
	TAR.NatTargetALL,
	RET.PassBestCasePer</CommandText>
      </Query>
