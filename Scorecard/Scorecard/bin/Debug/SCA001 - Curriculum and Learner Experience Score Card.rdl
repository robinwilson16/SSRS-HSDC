        <Field Name="AcademicYear">
          <DataField>AcademicYear</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LastYear">
          <DataField>LastYear</DataField>
          <rd:TypeName>System.String</rd:TypeName>
