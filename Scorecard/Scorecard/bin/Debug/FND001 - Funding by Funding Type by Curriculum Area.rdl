                  <Style />
                </Paragraph>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Value>When learners are studying English and Maths qualifications and/or in receipt of Learning Support, income for the delivery is re-apportioned to the English and Maths and Learning Support Curriculum Areas</Value>
                      <Style>
                        <FontFamily>Calibri</FontFamily>
                        <FontWeight>Normal</FontWeight>
                      </Style>
                    </TextRun>
                  </TextRuns>
