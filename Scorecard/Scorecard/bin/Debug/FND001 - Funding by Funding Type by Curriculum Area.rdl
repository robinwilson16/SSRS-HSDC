                                (
                                    FDE.TotalEarnedCashP01 
                                    - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                                    - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
