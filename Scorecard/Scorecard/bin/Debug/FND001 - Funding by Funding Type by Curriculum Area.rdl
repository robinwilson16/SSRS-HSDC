  <DataSets>
    <DataSet Name="FND001">
      <Query>
        <DataSourceName>InformationServices</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ILRReturn">
            <Value>=Parameters!ILRReturn.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CurriculumArea">
            <Value>=Parameters!CurriculumArea.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Team">
            <Value>=Parameters!Team.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear NVARCHAR(5) = '25/26'
DECLARE @ILRReturn NVARCHAR(3) = 'R07'
DECLARE @CurriculumArea NVARCHAR(50) = 'ALL'
DECLARE @Team NVARCHAR(50) = 'ALL'
*/


DECLARE @IsFinalReturn BIT = 1



--Apprenticeship Monthly Payments
DROP TABLE IF EXISTS #AppMonthlyPayments
SELECT
	LearnRefNumber = PAY.Learner_reference_number,
	AimSeqNumber = PAY.Aim_sequence_number,
	R01 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R01' THEN
					SUM (
						COALESCE ( PAY.[August_R01_total_payments], 0 )
						- COALESCE ( PAY.[August_R01_employer_additional_payments], 0 ) 
					)
			ELSE 
				NULL
		END,
	R02 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R02' THEN
					SUM (
						COALESCE ( PAY.[September_R02_total_payments], 0 )
						- COALESCE ( PAY.[September_R02_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R03 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R03' THEN
					SUM (
						COALESCE ( PAY.[October_R03_total_payments], 0 )
						- COALESCE ( PAY.[October_R03_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R04 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R04' THEN
					SUM (
						COALESCE ( PAY.[November_R04_total_payments], 0 )
						- COALESCE ( PAY.[November_R04_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R05 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R05' THEN
					SUM (
						COALESCE ( PAY.[December_R05_total_payments], 0 )
						- COALESCE ( PAY.[December_R05_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R06 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R06' THEN
					SUM (
						COALESCE ( PAY.[January_R06_total_payments], 0 )
						- COALESCE ( PAY.[January_R06_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R07 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R07' THEN
					SUM (
						COALESCE ( PAY.[February_R07_total_payments], 0 )
						- COALESCE ( PAY.[February_R07_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R08 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R08' THEN
					SUM (
						COALESCE ( PAY.[March_R08_total_payments], 0 )
						- COALESCE ( PAY.[March_R08_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R09 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R09' THEN
					SUM (
						COALESCE ( PAY.[April_R09_total_payments], 0 )
						- COALESCE ( PAY.[April_R09_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R10 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R10' THEN
					SUM (
						COALESCE ( PAY.[May_R10_total_payments], 0 )
						- COALESCE ( PAY.[May_R10_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R11 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R11' THEN
					SUM (
						COALESCE ( PAY.[June_R11_total_payments], 0 )
						- COALESCE ( PAY.[June_R11_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R12 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R12' THEN
					SUM (
						COALESCE ( PAY.[July_R12_total_payments], 0 )
						- COALESCE ( PAY.[July_R12_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R13 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R13' THEN
					SUM (
						COALESCE ( PAY.[R13_total_payments], 0 )
						- COALESCE ( PAY.[R13_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	R14 = 
		CASE 
			WHEN 
				@ILRReturn &gt;= 'R14' THEN
					SUM (
						COALESCE ( PAY.[R14_total_payments], 0 )
						- COALESCE ( PAY.[R14_employer_additional_payments], 0 )
					)
			ELSE 
				NULL
		END,
	Total = 
		SUM (
			COALESCE ( PAY.[August_R01_total_payments], 0 )
			- COALESCE ( PAY.[August_R01_employer_additional_payments], 0 ) 
		)
		+ SUM (
			COALESCE ( PAY.[September_R02_total_payments], 0 )
			- COALESCE ( PAY.[September_R02_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[October_R03_total_payments], 0 )
			- COALESCE ( PAY.[October_R03_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[November_R04_total_payments], 0 )
			- COALESCE ( PAY.[November_R04_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[December_R05_total_payments], 0 )
			- COALESCE ( PAY.[December_R05_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[January_R06_total_payments], 0 )
			- COALESCE ( PAY.[January_R06_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[February_R07_total_payments], 0 )
			- COALESCE ( PAY.[February_R07_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[March_R08_total_payments], 0 )
			- COALESCE ( PAY.[March_R08_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[April_R09_total_payments], 0 )
			- COALESCE ( PAY.[April_R09_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[May_R10_total_payments], 0 )
			- COALESCE ( PAY.[May_R10_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[June_R11_total_payments], 0 )
			- COALESCE ( PAY.[June_R11_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[July_R12_total_payments], 0 )
			- COALESCE ( PAY.[July_R12_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[R13_total_payments], 0 )
			- COALESCE ( PAY.[R13_employer_additional_payments], 0 )
		)
		+ SUM (
			COALESCE ( PAY.[R14_total_payments], 0 )
			- COALESCE ( PAY.[R14_employer_additional_payments], 0 )
		)
	INTO #AppMonthlyPayments
FROM FIS_AppsMonthlyPaymentReport PAY
GROUP BY
	PAY.Learner_reference_number,
	PAY.Aim_sequence_number



--Apprenticeship Future Funding
DROP TABLE IF EXISTS #AppFutureFunding
SELECT
	FDE.ProviderNumber,
    FDE.AcademicYear,
    FDE.ILRReturn,
    FDE.ILRReturnDate,
    FDE.LearnRefNumber,
    FDE.AimSeqNumber,
	R01 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R01' THEN FDE.TotalEarnedCashP01
			ELSE 
				NULL
		END,
	R02 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R02' THEN FDE.TotalEarnedCashP02
			ELSE 
				NULL
		END,
	R03 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R03' THEN FDE.TotalEarnedCashP03
			ELSE 
				NULL
		END,
	R04 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R04' THEN FDE.TotalEarnedCashP04
			ELSE 
				NULL
		END,
	R05 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R05' THEN FDE.TotalEarnedCashP05
			ELSE 
				NULL
		END,
	R06 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R06' THEN FDE.TotalEarnedCashP06
			ELSE 
				NULL
		END,
	R07 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R07' THEN FDE.TotalEarnedCashP07
			ELSE 
				NULL
		END,
	R08 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R08' THEN FDE.TotalEarnedCashP08
			ELSE 
				NULL
		END,
	R09 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R09' THEN FDE.TotalEarnedCashP09
			ELSE 
				NULL
		END,
	R10 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R10' THEN FDE.TotalEarnedCashP10
			ELSE 
				NULL
		END,
	R11 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R11' THEN FDE.TotalEarnedCashP11
			ELSE 
				NULL
		END,
	R12 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R12' THEN FDE.TotalEarnedCashP12
			ELSE 
				NULL
		END,
	R13 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R13' THEN 0
			ELSE 
				NULL
		END,
	R14 = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R14' THEN 0
			ELSE 
				NULL
		END,
	Total = 
		CASE
			WHEN 
				@ILRReturn &lt; 'R01' THEN 
					FDE.TotalEarnedCashP01
			WHEN 
				@ILRReturn &lt; 'R02' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
			WHEN 
				@ILRReturn &lt; 'R03' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
			WHEN 
				@ILRReturn &lt; 'R04' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
					+ FDE.TotalEarnedCashP04
			WHEN 
				@ILRReturn &lt; 'R05' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
					+ FDE.TotalEarnedCashP04
					+ FDE.TotalEarnedCashP05
			WHEN 
				@ILRReturn &lt; 'R06' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
					+ FDE.TotalEarnedCashP04
					+ FDE.TotalEarnedCashP05
					+ FDE.TotalEarnedCashP06
			WHEN 
				@ILRReturn &lt; 'R07' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
					+ FDE.TotalEarnedCashP04
					+ FDE.TotalEarnedCashP05
					+ FDE.TotalEarnedCashP06
					+ FDE.TotalEarnedCashP07
			WHEN 
				@ILRReturn &lt; 'R08' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
					+ FDE.TotalEarnedCashP04
					+ FDE.TotalEarnedCashP05
					+ FDE.TotalEarnedCashP06
					+ FDE.TotalEarnedCashP07
					+ FDE.TotalEarnedCashP08
			WHEN 
				@ILRReturn &lt; 'R09' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
					+ FDE.TotalEarnedCashP04
					+ FDE.TotalEarnedCashP05
					+ FDE.TotalEarnedCashP06
					+ FDE.TotalEarnedCashP07
					+ FDE.TotalEarnedCashP08
					+ FDE.TotalEarnedCashP09
			WHEN 
				@ILRReturn &lt; 'R10' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
					+ FDE.TotalEarnedCashP04
					+ FDE.TotalEarnedCashP05
					+ FDE.TotalEarnedCashP06
					+ FDE.TotalEarnedCashP07
					+ FDE.TotalEarnedCashP08
					+ FDE.TotalEarnedCashP09
					+ FDE.TotalEarnedCashP10
			WHEN 
				@ILRReturn &lt; 'R11' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
					+ FDE.TotalEarnedCashP04
					+ FDE.TotalEarnedCashP05
					+ FDE.TotalEarnedCashP06
					+ FDE.TotalEarnedCashP07
					+ FDE.TotalEarnedCashP08
					+ FDE.TotalEarnedCashP09
					+ FDE.TotalEarnedCashP10
					+ FDE.TotalEarnedCashP11
			WHEN 
				@ILRReturn &lt; 'R12' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
					+ FDE.TotalEarnedCashP04
					+ FDE.TotalEarnedCashP05
					+ FDE.TotalEarnedCashP06
					+ FDE.TotalEarnedCashP07
					+ FDE.TotalEarnedCashP08
					+ FDE.TotalEarnedCashP09
					+ FDE.TotalEarnedCashP10
					+ FDE.TotalEarnedCashP11
					+ FDE.TotalEarnedCashP12
			WHEN 
				@ILRReturn &lt; 'R13' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
					+ FDE.TotalEarnedCashP04
					+ FDE.TotalEarnedCashP05
					+ FDE.TotalEarnedCashP06
					+ FDE.TotalEarnedCashP07
					+ FDE.TotalEarnedCashP08
					+ FDE.TotalEarnedCashP09
					+ FDE.TotalEarnedCashP10
					+ FDE.TotalEarnedCashP11
					+ FDE.TotalEarnedCashP12
			WHEN 
				@ILRReturn &lt; 'R14' THEN 
					FDE.TotalEarnedCashP01
					+ FDE.TotalEarnedCashP02
					+ FDE.TotalEarnedCashP03
					+ FDE.TotalEarnedCashP04
					+ FDE.TotalEarnedCashP05
					+ FDE.TotalEarnedCashP06
					+ FDE.TotalEarnedCashP07
					+ FDE.TotalEarnedCashP08
					+ FDE.TotalEarnedCashP09
					+ FDE.TotalEarnedCashP10
					+ FDE.TotalEarnedCashP11
					+ FDE.TotalEarnedCashP12
			ELSE 
				NULL
		END
	INTO #AppFutureFunding
FROM FIS_FundingDataExtra FDE
WHERE
	FDE.AcademicYear = @AcademicYear
	AND FDE.ILRReturn = @ILRReturn
	AND FDE.IsFinalReturn = @IsFinalReturn




SELECT
    ProviderNumber = FD.ProviderNumber,
    ProviderName = FD.providerName,
    AcademicYear = FD.AcademicYear,
    ILRReturn = FD.ILRReturn,
    ILRReturnDate = FD.ILRReturnDate,
    LastILRReturn = 'R' + FORMAT ( CAST ( RIGHT ( FD.ILRReturn, 2 ) AS INT ) - 1, '#00' ),
    RecordType = 'Main ILR',
    RecordTypeOrder = 1,
    CurriculumAreaCode = FD.CollegeLevel1Code,
    CurriculumAreaName = FD.CollegeLevel1Name,
    CurriculumAreaHead = CAO.FORENAME + ' ' + CAO.SURNAME + ' (' + CAO.FES_STAFF_CODE + ')',
    TeamCode = FD.CollegeLevel2Code,
    TeamName = FD.CollegeLevel2Name,
    TeamHead = TEAMO.FORENAME + ' ' + TEAMO.SURNAME + ' (' + TEAMO.FES_STAFF_CODE + ')',
    FundLineCategoryOrder = FD.FundLineCategoryOrder,
    FundLineCategory = FD.FundLineCategory,
    FundLineSubCategoryOrder = FD.FundLineSubCategoryOrder,
    FundLineSubCategory = FundLineSubCategory,
    FundLine = FD.FundLine,
    FundingType = 
        CASE
            WHEN FD.FundLine = 'DA/GLA Adult Skills Fund free courses for jobs (non-procured)' THEN FD.FundLine
            WHEN FD.FundLineCategory = 'Apprenticeships' AND FD.IsCarryIn = 1 THEN 'Apprenticeships - Carry-in'
            WHEN FD.FundLineCategory = 'Apprenticeships' THEN 'Apprenticeships - New Starts'
            ELSE FD.FundLineSubCategory
        END,
    NominalCode = 
        CASE
            WHEN FD.FundLineSubCategory = 'Study Programmes' THEN 50101
            WHEN FD.FundLineSubCategory = 'T Levels' THEN 50101
            WHEN FD.FundLine = 'DA/GLA Adult Skills Fund free courses for jobs (non-procured)' THEN 50106
            WHEN FD.FundLineSubCategory = 'DFE - ESFA' THEN 50106
            WHEN FD.FundLineSubCategory = 'Devolved - NEMCA' THEN 50104
            WHEN FD.FundLineSubCategory = 'Devolved - TVCA' THEN 50105
            WHEN FD.FundLineCategory = 'Apprenticeships' AND FD.IsCarryIn = 1 THEN 50205
            WHEN FD.FundLineCategory = 'Apprenticeships' THEN 50201
            ELSE 99999
        END,
    FundCode = 
        CASE
            WHEN FD.FundLineSubCategory = 'Study Programmes' THEN 'F-001'
            WHEN FD.FundLineSubCategory = 'T Levels' THEN 'F-001'
            WHEN FD.FundLine = 'DA/GLA Adult Skills Fund free courses for jobs (non-procured)' THEN 'F-019'
            WHEN FD.FundLineSubCategory = 'DFE - ESFA' THEN 'F-019'
            WHEN FD.FundLineSubCategory = 'Devolved - NEMCA' THEN 'F-020'
            WHEN FD.FundLineSubCategory = 'Devolved - TVCA' THEN 'F-021'
            WHEN FD.FundLineCategory = 'Apprenticeships' AND FD.IsCarryIn = 1 THEN 'F-999'
            WHEN FD.FundLineCategory = 'Apprenticeships' THEN 'F-999'
            ELSE 'F-999'
        END,
    BudgetTotal = COALESCE ( TART.Budget, 0 ),
    BudgetFundLineCategory = COALESCE ( TARF.Budget, 0 ),
    BudgetMeasure = COALESCE ( TARM.Budget, 0 ),
    BudgetCurriculumAreaAndMeasure = COALESCE ( TAR.Budget, 0 ),
    TargetTotal = COALESCE ( TART.Target, 0 ),
    TargetFundLineCategory = COALESCE ( TARF.Target, 0 ),
    TargetMeasure = COALESCE ( TARM.Target, 0 ),
    TargetCurriculumAreaAndMeasure = COALESCE ( TAR.Target, 0 ),
    StandardCode = FD.StandardCode,
    StandardName = FD.StandardName,
    LearningAimCode = FD.LearningAimCode,
    LearningAimTitle = FD.LearningAimTitle,
    StandardAimCode = COALESCE ( CAST ( FD.StandardCode AS VARCHAR(50) ), FD.LearningAimCode ),
    StandardAimTitle = COALESCE ( FD.StandardName, FD.LearningAimTitle ),
	CourseCode = FD.CourseCode,
	CourseTitle = FD.CourseTitle,
	CourseInstance = FD.CourseInstance,
	CarryIn = CASE WHEN FD.IsCarryIn = 1 THEN 'Carry In' ELSE 'New Start' END,
    FD.LearnRefNumber,
    FD.Surname,
    FD.Forename,
    FD.IsFundedStart,
    FD.IsMainAimInFundModel,
    FD.IsMainAim,

    --R01Levy = COALESCE ( PAY.[August_R01_levy_payments], 0 ),
    --R01CoInvestment = COALESCE ( PAY.[August_R01_co_investment_payments], 0 ),
    --R01CoInvestmentBelowBand = COALESCE ( PAY.[August_R01_co_investment_below_band_upper_limit_due_from_employer], 0 ),
    --R01Employer = COALESCE ( PAY.[August_R01_employer_additional_payments], 0 ),
    --R01Provider = COALESCE ( PAY.[August_R01_provider_additional_payments], 0 ),
    --R01Additional = COALESCE ( PAY.[August_R01_apprentice_additional_payments], 0 ),
    --R01EngMat = COALESCE ( PAY.[August_R01_English_and_maths_payments], 0 ),
    --R01LearningSupport = COALESCE ( PAY.[August_R01_payments_for_learning_support], 0 ),
    R01MinusEngMaths = 
        CASE
            WHEN FD.FundLineCategory = 'Apprenticeships' 
            THEN
                COALESCE ( PAY.R01, FDA.R01, 0 )
            ELSE 
                CASE
                    WHEN FD.IsFundedStart = 1 THEN 
                        FDE.TotalEarnedCashP01 
                        - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                    ELSE FDE.TotalEarnedCashP01
                END
        END,
    R01MinusLearningSupport = 
        CASE
            WHEN FD.FundLineCategory = 'Apprenticeships' 
            THEN
                COALESCE ( PAY.R01, FDA.R01, 0 )
            ELSE 
                CASE
                    WHEN FD.IsFundedStart = 1 THEN 
                        FDE.TotalEarnedCashP01 
                        - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                    ELSE FDE.TotalEarnedCashP01
                END
        END,
    R01MinusEngMathsLearnSup = 
        CASE
            WHEN FD.FundLineCategory = 'Apprenticeships' 
            THEN
                COALESCE ( PAY.R01, FDA.R01, 0 )
            ELSE 
                CASE
                    WHEN FD.IsFundedStart = 1 THEN 
                        FDE.TotalEarnedCashP01 
