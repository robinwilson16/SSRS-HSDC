    <DataSet Name="AcademicYear">
      <Query>
        <DataSourceName>InformationServices</DataSourceName>
        <CommandText>SELECT DISTINCT
	Code = FD.AcademicYear,
	Description = FD.AcademicYear
FROM FIS_FundingData FD
WHERE
	FD.IsFinalReturn = 1
ORDER BY
	FD.AcademicYear</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="AcademicYearCur">
      <Query>
        <DataSourceName>InformationServices</DataSourceName>
        <CommandText>/*
DECLARE @AcademicYear VARCHAR(5) = '25/26'
*/

SET DATEFORMAT ymd

SELECT DISTINCT
	Code = FD.AcademicYear,
	Description = FD.AcademicYear
FROM FIS_FundingData FD
WHERE
	FD.IsFinalReturn = 1
	AND CAST ( '20' + LEFT ( FD.AcademicYear, 2 ) + '-08-01' AS DATE ) &lt;= CAST ( GetDate() AS DATE )
	AND CAST ( '20' + RIGHT ( FD.AcademicYear, 2 ) + '-07-31' AS DATE ) &gt;= CAST ( GetDate() AS DATE )
ORDER BY
	FD.AcademicYear</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ILRReturn">
      <Query>
        <DataSourceName>InformationServices</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear NVARCHAR(5) = '24/25'
*/

SELECT DISTINCT
	Code = FD.ILRReturn,
	Description = FD.ILRReturn
FROM FIS_FundingData FD
WHERE
	FD.AcademicYear = @AcademicYear
	AND FD.IsFinalReturn = 1
ORDER BY
	FD.ILRReturn</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ILRReturnDefault">
      <Query>
        <DataSourceName>InformationServices</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear NVARCHAR(5) = '24/25'
*/

SELECT
	Code = MAX ( FD.ILRReturn ),
	Description = MAX ( FD.ILRReturn )
FROM FIS_FundingData FD
WHERE
	FD.AcademicYear = @AcademicYear
	AND FD.IsFinalReturn = 1</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CurriculumArea">
      <Query>
        <DataSourceName>InformationServices</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ILRReturn">
            <Value>=Parameters!ILRReturn.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear NVARCHAR(5) = '25/26'
DECLARE @ILRReturn NVARCHAR(3) = 'R07'
*/


DECLARE @IsFinalReturn BIT = 1


SELECT
	Code = 'ALL',
	Description = '-- All Curriculum Areas --'

UNION ALL

SELECT DISTINCT
	Code = FD.CollegeLevel1Code,
	Description = FD.CollegeLevel1Code + ' - ' + FD.CollegeLevel1Name
FROM FIS_FundingData FD
WHERE
	FD.AcademicYear = @AcademicYear
	AND FD.ILRReturn = @ILRReturn
	AND FD.IsFinalReturn = @IsFinalReturn

ORDER BY
	Description</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Team">
      <Query>
        <DataSourceName>InformationServices</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AcademicYear">
            <Value>=Parameters!AcademicYear.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ILRReturn">
            <Value>=Parameters!ILRReturn.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CurriculumArea">
            <Value>=Parameters!CurriculumArea.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/*
DECLARE @AcademicYear NVARCHAR(5) = '25/26'
DECLARE @ILRReturn NVARCHAR(3) = 'R07'
DECLARE @CurriculumArea NVARCHAR(50) = 'ALL'
*/

DECLARE @IsFinalReturn BIT = 1


SELECT
	Code = 'ALL',
	Description = '-- All Teams --'

UNION ALL

SELECT DISTINCT
	Code = FD.CollegeLevel2Code,
	Description = FD.CollegeLevel2Code + ' - ' + FD.CollegeLevel2Name
FROM FIS_FundingData FD
WHERE
	FD.AcademicYear = @AcademicYear
	AND FD.ILRReturn = @ILRReturn
	AND FD.IsFinalReturn = @IsFinalReturn
	AND ( FD.CollegeLevel1Code IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )

ORDER BY
	Description</CommandText>
      </Query>
      <Fields>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
