                        + COALESCE ( PAY.R03, FDA.R03, 0 )
                        + COALESCE ( PAY.R04, FDA.R04, 0 )
                        + COALESCE ( PAY.R05, FDA.R05, 0 )
                        + COALESCE ( PAY.R06, FDA.R06, 0 )
                        + COALESCE ( PAY.R07, FDA.R07, 0 )
                        + COALESCE ( PAY.R08, FDA.R08, 0 )
                        + COALESCE ( PAY.R09, FDA.R09, 0 )
                    ELSE
                        FDE.TotalEarnedCashP01
                        + FDE.TotalEarnedCashP02
                        + FDE.TotalEarnedCashP03
                        + FDE.TotalEarnedCashP04
                        + FDE.TotalEarnedCashP05
                        + FDE.TotalEarnedCashP06
                        + FDE.TotalEarnedCashP07
                        + FDE.TotalEarnedCashP08
                        + FDE.TotalEarnedCashP09
                END
            WHEN FD.ILRReturn = 'R10' THEN
                CASE
                    WHEN FD.FundLineCategory = 'Apprenticeships' THEN 
                        COALESCE ( PAY.R01, FDA.R01, 0 )
                        + COALESCE ( PAY.R02, FDA.R02, 0 )
                        + COALESCE ( PAY.R03, FDA.R03, 0 )
                        + COALESCE ( PAY.R04, FDA.R04, 0 )
                        + COALESCE ( PAY.R05, FDA.R05, 0 )
                        + COALESCE ( PAY.R06, FDA.R06, 0 )
                        + COALESCE ( PAY.R07, FDA.R07, 0 )
                        + COALESCE ( PAY.R08, FDA.R08, 0 )
                        + COALESCE ( PAY.R09, FDA.R09, 0 )
                        + COALESCE ( PAY.R10, FDA.R10, 0 )
                    ELSE
                        FDE.TotalEarnedCashP01
                        + FDE.TotalEarnedCashP02
                        + FDE.TotalEarnedCashP03
                        + FDE.TotalEarnedCashP04
                        + FDE.TotalEarnedCashP05
                        + FDE.TotalEarnedCashP06
                        + FDE.TotalEarnedCashP07
                        + FDE.TotalEarnedCashP08
                        + FDE.TotalEarnedCashP09
                        + FDE.TotalEarnedCashP10
                END
            WHEN FD.ILRReturn = 'R11' THEN
                CASE
                    WHEN FD.FundLineCategory = 'Apprenticeships' THEN 
                        COALESCE ( PAY.R01, FDA.R01, 0 )
                        + COALESCE ( PAY.R02, FDA.R02, 0 )
                        + COALESCE ( PAY.R03, FDA.R03, 0 )
                        + COALESCE ( PAY.R04, FDA.R04, 0 )
                        + COALESCE ( PAY.R05, FDA.R05, 0 )
                        + COALESCE ( PAY.R06, FDA.R06, 0 )
                        + COALESCE ( PAY.R07, FDA.R07, 0 )
                        + COALESCE ( PAY.R08, FDA.R08, 0 )
                        + COALESCE ( PAY.R09, FDA.R09, 0 )
                        + COALESCE ( PAY.R10, FDA.R10, 0 )
                        + COALESCE ( PAY.R11, FDA.R11, 0 )
                    ELSE
                        FDE.TotalEarnedCashP01
                        + FDE.TotalEarnedCashP02
                        + FDE.TotalEarnedCashP03
                        + FDE.TotalEarnedCashP04
                        + FDE.TotalEarnedCashP05
                        + FDE.TotalEarnedCashP06
                        + FDE.TotalEarnedCashP07
                        + FDE.TotalEarnedCashP08
                        + FDE.TotalEarnedCashP09
                        + FDE.TotalEarnedCashP10
                        + FDE.TotalEarnedCashP11
                END
            WHEN FD.ILRReturn = 'R12' THEN
                CASE
                    WHEN FD.FundLineCategory = 'Apprenticeships' THEN 
                        COALESCE ( PAY.R01, FDA.R01, 0 )
                        + COALESCE ( PAY.R02, FDA.R02, 0 )
                        + COALESCE ( PAY.R03, FDA.R03, 0 )
                        + COALESCE ( PAY.R04, FDA.R04, 0 )
                        + COALESCE ( PAY.R05, FDA.R05, 0 )
                        + COALESCE ( PAY.R06, FDA.R06, 0 )
                        + COALESCE ( PAY.R07, FDA.R07, 0 )
                        + COALESCE ( PAY.R08, FDA.R08, 0 )
                        + COALESCE ( PAY.R09, FDA.R09, 0 )
                        + COALESCE ( PAY.R10, FDA.R10, 0 )
                        + COALESCE ( PAY.R11, FDA.R11, 0 )
                        + COALESCE ( PAY.R12, FDA.R12, 0 )
                    ELSE
                        FDE.TotalEarnedCashP01
                        + FDE.TotalEarnedCashP02
                        + FDE.TotalEarnedCashP03
                        + FDE.TotalEarnedCashP04
                        + FDE.TotalEarnedCashP05
                        + FDE.TotalEarnedCashP06
                        + FDE.TotalEarnedCashP07
                        + FDE.TotalEarnedCashP08
                        + FDE.TotalEarnedCashP09
                        + FDE.TotalEarnedCashP10
                        + FDE.TotalEarnedCashP11
                        + FDE.TotalEarnedCashP12
                END
            WHEN FD.ILRReturn = 'R13' THEN
                CASE
                    WHEN FD.FundLineCategory = 'Apprenticeships' THEN 
                        COALESCE ( PAY.R01, FDA.R01, 0 )
                        + COALESCE ( PAY.R02, FDA.R02, 0 )
                        + COALESCE ( PAY.R03, FDA.R03, 0 )
                        + COALESCE ( PAY.R04, FDA.R04, 0 )
                        + COALESCE ( PAY.R05, FDA.R05, 0 )
                        + COALESCE ( PAY.R06, FDA.R06, 0 )
                        + COALESCE ( PAY.R07, FDA.R07, 0 )
                        + COALESCE ( PAY.R08, FDA.R08, 0 )
                        + COALESCE ( PAY.R09, FDA.R09, 0 )
                        + COALESCE ( PAY.R10, FDA.R10, 0 )
                        + COALESCE ( PAY.R11, FDA.R11, 0 )
                        + COALESCE ( PAY.R12, FDA.R12, 0 )
                        + COALESCE ( PAY.R13, 0 )
                    ELSE
                        FDE.TotalEarnedCashP01
                        + FDE.TotalEarnedCashP02
                        + FDE.TotalEarnedCashP03
                        + FDE.TotalEarnedCashP04
                        + FDE.TotalEarnedCashP05
                        + FDE.TotalEarnedCashP06
                        + FDE.TotalEarnedCashP07
                        + FDE.TotalEarnedCashP08
                        + FDE.TotalEarnedCashP09
                        + FDE.TotalEarnedCashP10
                        + FDE.TotalEarnedCashP11
                        + FDE.TotalEarnedCashP12
                END
            WHEN FD.ILRReturn = 'R14' THEN
                CASE
                    WHEN FD.FundLineCategory = 'Apprenticeships' THEN 
                        COALESCE ( PAY.R01, FDA.R01, 0 )
                        + COALESCE ( PAY.R02, FDA.R02, 0 )
                        + COALESCE ( PAY.R03, FDA.R03, 0 )
                        + COALESCE ( PAY.R04, FDA.R04, 0 )
                        + COALESCE ( PAY.R05, FDA.R05, 0 )
                        + COALESCE ( PAY.R06, FDA.R06, 0 )
                        + COALESCE ( PAY.R07, FDA.R07, 0 )
                        + COALESCE ( PAY.R08, FDA.R08, 0 )
                        + COALESCE ( PAY.R09, FDA.R09, 0 )
                        + COALESCE ( PAY.R10, FDA.R10, 0 )
                        + COALESCE ( PAY.R11, FDA.R11, 0 )
                        + COALESCE ( PAY.R12, FDA.R12, 0 )
                        + COALESCE ( PAY.R13, 0 )
                        + COALESCE ( PAY.R14, 0 )
                    ELSE
                        FDE.TotalEarnedCashP01
                        + FDE.TotalEarnedCashP02
                        + FDE.TotalEarnedCashP03
                        + FDE.TotalEarnedCashP04
                        + FDE.TotalEarnedCashP05
                        + FDE.TotalEarnedCashP06
                        + FDE.TotalEarnedCashP07
                        + FDE.TotalEarnedCashP08
                        + FDE.TotalEarnedCashP09
                        + FDE.TotalEarnedCashP10
                        + FDE.TotalEarnedCashP11
                        + FDE.TotalEarnedCashP12
                END
            ELSE 0
        END,

    IncomeToFinalPeriodMinusEngMathsLearnSup = 
        CASE
            WHEN FD.FundLineCategory = 'Apprenticeships' THEN 
                COALESCE ( PAY.R01, FDA.R01, 0 )
                + COALESCE ( PAY.R02, FDA.R02, 0 )
                + COALESCE ( PAY.R03, FDA.R03, 0 )
                + COALESCE ( PAY.R04, FDA.R04, 0 )
                + COALESCE ( PAY.R05, FDA.R05, 0 )
                + COALESCE ( PAY.R06, FDA.R06, 0 )
                + COALESCE ( PAY.R07, FDA.R07, 0 )
                + COALESCE ( PAY.R08, FDA.R08, 0 )
                + COALESCE ( PAY.R09, FDA.R09, 0 )
                + COALESCE ( PAY.R10, FDA.R10, 0 )
                + COALESCE ( PAY.R11, FDA.R11, 0 )
                + COALESCE ( PAY.R12, FDA.R12, 0 )
                + COALESCE ( PAY.R13, 0 )
                + COALESCE ( PAY.R14, 0 )
            ELSE
                CASE
                    WHEN FD.IsFundedStart = 1 THEN
                        (
                            FDE.TotalEarnedCashP01 
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                        + (
                            FDE.TotalEarnedCashP02
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                        + (
                            FDE.TotalEarnedCashP03
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                        + (
                            FDE.TotalEarnedCashP04
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                        + (
                            FDE.TotalEarnedCashP05
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                        + (
                            FDE.TotalEarnedCashP06
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                        + (
                            FDE.TotalEarnedCashP07
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                        + (
                            FDE.TotalEarnedCashP08
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                        + (
                            FDE.TotalEarnedCashP09
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                        + (
                            FDE.TotalEarnedCashP10
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                        + (
                            FDE.TotalEarnedCashP11
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                        + (
                            FDE.TotalEarnedCashP12
                            - ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 )
                            - ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 )
                        )
                    ELSE
                        FDE.TotalEarnedCashP01
                        + FDE.TotalEarnedCashP02
                        + FDE.TotalEarnedCashP03
                        + FDE.TotalEarnedCashP04
                        + FDE.TotalEarnedCashP05
                        + FDE.TotalEarnedCashP06
                        + FDE.TotalEarnedCashP07
                        + FDE.TotalEarnedCashP08
                        + FDE.TotalEarnedCashP09
                        + FDE.TotalEarnedCashP10
                        + FDE.TotalEarnedCashP11
                        + FDE.TotalEarnedCashP12
                END
        END,

    IncomeToFinalPeriod = 
        CASE
            WHEN FD.FundLineCategory = 'Apprenticeships' 
            THEN
                COALESCE ( PAY.R01, FDA.R01, 0 )
                + COALESCE ( PAY.R02, FDA.R02, 0 )
                + COALESCE ( PAY.R03, FDA.R03, 0 )
                + COALESCE ( PAY.R04, FDA.R04, 0 )
                + COALESCE ( PAY.R05, FDA.R05, 0 )
                + COALESCE ( PAY.R06, FDA.R06, 0 )
                + COALESCE ( PAY.R07, FDA.R07, 0 )
                + COALESCE ( PAY.R08, FDA.R08, 0 )
                + COALESCE ( PAY.R09, FDA.R09, 0 )
                + COALESCE ( PAY.R10, FDA.R10, 0 )
                + COALESCE ( PAY.R11, FDA.R11, 0 )
                + COALESCE ( PAY.R12, FDA.R12, 0 )
                + COALESCE ( PAY.R13, 0 )
                + COALESCE ( PAY.R14, 0 )
            ELSE FD.TotalEarnedCashYearEnd
        END,

    FutureAchievePayment = FD.FutureAchievePayment,

    CoreProgrammeFunding = 
		( FD.NationalFundingRate * FD.PrvRetentFactHist * FD.ProgWeightNew ) 
		* FD.AreaCostFact1618Hist,
	TotalProgrammeFunding = 
		(
			( FD.NationalFundingRate * FD.PrvRetentFactHist * FD.ProgWeightNew ) 
			* FD.AreaCostFact1618Hist
		)
		- FD.ConditionOfFundingAdjustment
		+ (
			FD.LearnerEnglishMathsFundingRate
			*
			FD.LearnerEnglishMathsInstances
		)
		+ FD.CoreMathsPremium
        + FD.Block1DisadvUpliftCash
		+ FD.Block2DisadvUpliftCash
		+ FD.HighValueCoursePremium
		+ FD.TLevelIndustryPlacementFunding,

    PrvRetentFactHist = FD.PrvRetentFactHist,
    ProgWeightHist = FD.ProgWeightHist,
    ProgWeightNew = FD.ProgWeightNew,
    LearnerEnglishMathsFundingRate = FD.LearnerEnglishMathsFundingRate,
    LearnerEnglishMathsInstances = FD.LearnerEnglishMathsInstances,
    EnglishAndMathsFunding = FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances,
    Block1DisadvUpliftRate = FD.Block1DisadvUpliftRate, --Post Codes
    Block1DisadvUpliftCash = FD.Block1DisadvUpliftCash,
    Block2DisadvUpliftRate = FD.Block1DisadvUpliftRate,
    Block2DisadvElementsNew = FD.Block2DisadvElementsNew,
    Block2DisadvUpliftCash = FD.Block2DisadvUpliftCash, --English and Maths Low Ach
    LargeProgrammeUplift = FD.LargeProgrammeUplift,
    AreaCostFact1618Hist = FD.AreaCostFact1618Hist,
    ConditionOfFundingAdjustment = FD.ConditionOfFundingAdjustment,
    AdvancedMathsPremium = FD.AdvancedMathsPremium,
    CoreMathsPremium = FD.CoreMathsPremium,
    HighValueCoursePremium = FD.HighValueCoursePremium,
    TLevelIndustryPlacementFunding = FD.TLevelIndustryPlacementFunding
	--FundingToCurrentPeriod = FD.TotalEarnedCashToPeriod,
	--TotalFunding = FD.TotalEarnedCashYearEnd
FROM FIS_FundingData FD
INNER JOIN FIS_FundingDataExtra FDE
    ON FDE.ProviderNumber = FD.ProviderNumber
    AND FDE.AcademicYear = FD.AcademicYear
    AND FDE.ILRReturn = FD.ILRReturn
    AND FDE.ILRReturnDate = FD.ILRReturnDate
    AND FDE.LearnRefNumber = FD.LearnRefNumber
    AND FDE.AimSeqNumber = FD.AimSeqNumber
LEFT JOIN #AppFutureFunding FDA
    ON FDA.ProviderNumber = FD.ProviderNumber
    AND FDA.AcademicYear = FD.AcademicYear
    AND FDA.ILRReturn = FD.ILRReturn
    AND FDA.ILRReturnDate = FD.ILRReturnDate
    AND FDA.LearnRefNumber = FD.LearnRefNumber
    AND FDA.AimSeqNumber = FD.AimSeqNumber
LEFT JOIN #AppMonthlyPayments PAY
	ON PAY.LearnRefNumber = FD.LearnRefNumber
    AND PAY.AimSeqNumber = FD.AimSeqNumber
LEFT JOIN [EBS-DB\EBS].ebs.dbo.ORGANISATION_UNITS CA
    ON CA.ORGANISATION_CODE = FD.CollegeLevel1Code
LEFT JOIN [EBS-DB\EBS].ebs.dbo.ORGANISATION_UNITS TEAM
    ON TEAM.ORGANISATION_CODE = FD.CollegeLevel2Code
LEFT JOIN [EBS-DB\EBS].ebs.dbo.PEOPLE CAO
	ON CAO.PERSON_CODE = CA.FES_DEPARTMENT_HEAD
LEFT JOIN [EBS-DB\EBS].ebs.dbo.PEOPLE TEAMO
	ON TEAMO.PERSON_CODE = TEAM.FES_DEPARTMENT_HEAD
LEFT JOIN (
    SELECT
        TAR.TeamCode,
        TAR.Measure,
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    GROUP BY
        TAR.TeamCode,
        TAR.Measure
) TAR
    ON TAR.TeamCode = FD.CollegeLevel1Code
    AND TAR.Measure = 
        CASE
            WHEN FD.FundLineSubCategory = 'Study Programmes' THEN 50101
            WHEN FD.FundLineSubCategory = 'T Levels' THEN 50101
            WHEN FD.FundLine = 'DA/GLA Adult Skills Fund free courses for jobs (non-procured)' THEN 50106
            WHEN FD.FundLineSubCategory = 'DFE - ESFA' THEN 50106
            WHEN FD.FundLineSubCategory = 'Devolved - NEMCA' THEN 50104
            WHEN FD.FundLineSubCategory = 'Devolved - TVCA' THEN 50105
            WHEN FD.FundLineCategory = 'Apprenticeships' AND FD.IsCarryIn = 1 THEN 50205
            WHEN FD.FundLineCategory = 'Apprenticeships' THEN 50201
            ELSE 99999
        END
LEFT JOIN (
    SELECT
        FundLineCategory = 
            CASE
                WHEN TAR.Measure = '50101' THEN '16-19 Funding'
                WHEN TAR.Measure IN (
                    '50104',
                    '50105',
                    '50106'
                ) THEN 'Adult Skills Fund'
                WHEN TAR.Measure IN (
                    '50201',
                    '50205'
                ) THEN 'Apprenticeships'
                ELSE 'Other'
            END,
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    GROUP BY
        CASE
            WHEN TAR.Measure = '50101' THEN '16-19 Funding'
            WHEN TAR.Measure IN (
                '50104',
                '50105',
                '50106'
            ) THEN 'Adult Skills Fund'
            WHEN TAR.Measure IN (
                '50201',
                '50205'
            ) THEN 'Apprenticeships'
            ELSE 'Other'
        END
) TARF
    ON TARF.FundLineCategory = FD.FundLineCategory
LEFT JOIN (
    SELECT
        TAR.Measure,
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    GROUP BY
        TAR.Measure
) TARM
    ON TARM.Measure = 
        CASE
            WHEN FD.FundLineSubCategory = 'Study Programmes' THEN 50101
            WHEN FD.FundLineSubCategory = 'T Levels' THEN 50101
            WHEN FD.FundLine = 'DA/GLA Adult Skills Fund free courses for jobs (non-procured)' THEN 50106
            WHEN FD.FundLineSubCategory = 'DFE - ESFA' THEN 50106
            WHEN FD.FundLineSubCategory = 'Devolved - NEMCA' THEN 50104
            WHEN FD.FundLineSubCategory = 'Devolved - TVCA' THEN 50105
            WHEN FD.FundLineCategory = 'Apprenticeships' AND FD.IsCarryIn = 1 THEN 50205
            WHEN FD.FundLineCategory = 'Apprenticeships' THEN 50201
            ELSE 99999
        END
LEFT JOIN (
    SELECT
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
) TART
    ON 1 = 1
WHERE
	FD.AcademicYear = @AcademicYear
	AND FD.ILRReturn = @ILRReturn
	AND FD.IsFinalReturn = @IsFinalReturn
    AND ( FD.CollegeLevel1Code IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    AND ( FD.CollegeLevel2Code IN ( @Team ) OR 'ALL' IN ( @Team ) )
    AND FD.FundLineCategory NOT IN (
        'Advanced Learner Loan',
        'Full Cost'
    )
	--AND FD.IsFundedStart = 1
    --AND FD.StandardCode = '550'
    --AND FD.LearnRefNumber = '110801'

UNION ALL

SELECT
	ProviderNumber = FD.ProviderNumber,
    ProviderName = FD.providerName,
    AcademicYear = FD.AcademicYear,
	ILRReturn = FD.ILRReturn,
	ILRReturnDate = FD.ILRReturnDate,
    LastILRReturn = 'R' + FORMAT ( CAST ( RIGHT ( FD.ILRReturn, 2 ) AS INT ) - 1, '#00' ),
    RecordType = 'English and Maths',
    RecordTypeOrder = 2,
	CurriculumAreaCode = CA.ORGANISATION_CODE,
	CurriculumAreaName = CA.FES_FULL_NAME,
    CurriculumAreaHead = CAO.FORENAME + ' ' + CAO.SURNAME + ' (' + CAO.FES_STAFF_CODE + ')',
	TeamCode = TEAM.ORGANISATION_CODE,
	TeamName = TEAM.FES_FULL_NAME,
    TeamHead = TEAMO.FORENAME + ' ' + TEAMO.SURNAME + ' (' + TEAMO.FES_STAFF_CODE + ')',
	FundLineCategoryOrder = FD.FundLineCategoryOrder,
	FundLineCategory = FD.FundLineCategory,
	FundLineSubCategoryOrder = FD.FundLineSubCategoryOrder,
	FundLineSubCategory = FundLineSubCategory,
	FundLine = FD.FundLine,
    FundingType = FD.FundLineSubCategory,
    NominalCode = 50101,
    FundCode = 'F-001',
    BudgetTotal = COALESCE ( TART.Budget, 0 ),
    BudgetFundLineCategory = COALESCE ( TARF.Budget, 0 ),
    BudgetMeasure = COALESCE ( TARM.Budget, 0 ),
    BudgetCurriculumAreaAndMeasure = COALESCE ( TAR.Budget, 0 ),
    TargetTotal = COALESCE ( TART.Target, 0 ),
    TargetFundLineCategory = COALESCE ( TARF.Target, 0 ),
    TargetMeasure = COALESCE ( TARM.Target, 0 ),
    TargetCurriculumAreaAndMeasure = COALESCE ( TAR.Target, 0 ),
    StandardCode = FD.StandardCode,
    StandardName = FD.StandardName,
    LearningAimCode = FD.LearningAimCode,
    LearningAimTitle = FD.LearningAimTitle,
    StandardAimCode = COALESCE ( CAST ( FD.StandardCode AS VARCHAR(50) ), FD.LearningAimCode ),
    StandardAimTitle = COALESCE ( FD.StandardName, FD.LearningAimTitle ),
	CourseCode = FD.CourseCode,
	CourseTitle = FD.CourseTitle,
	CourseInstance = FD.CourseInstance,
	CarryIn = CASE WHEN FD.IsCarryIn = 1 THEN 'Carry In' ELSE 'New Start' END,
    FD.LearnRefNumber,
    FD.Surname,
    FD.Forename,
    FD.IsFundedStart,
    FD.IsMainAimInFundModel,
    FD.IsMainAim,
    R01MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R01MinusLearningSupport = 0,
    R01MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R01Total = 0,
    R02MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R02MinusLearningSupport = 0,
    R02MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R02Total = 0,
    R03MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R03MinusLearningSupport = 0,
    R03MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R03Total = 0,
    R04MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R04MinusLearningSupport = 0,
    R04MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R04Total = 0,
    R05MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R05MinusLearningSupport = 0,
    R05MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R05Total = 0,
    R06MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R06MinusLearningSupport = 0,
    R06MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R06Total = 0,
    R07MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R07MinusLearningSupport = 0,
    R07MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R07Total = 0,
    R08MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R08MinusLearningSupport = 0,
    R08MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R08Total = 0,
    R09MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R09MinusLearningSupport = 0,
    R09MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R09Total = 0,
    R10MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R10MinusLearningSupport = 0,
    R10MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R10Total = 0,
    R11MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R11MinusLearningSupport = 0,
    R11MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R11Total = 0,
    R12MinusEngMaths = ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12,
    R12MinusLearningSupport = 0,
    R12MinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ),
    R12Total = 0,
    R13MinusEngMaths = 0,
    R13MinusLearningSupport = 0,
    R13MinusEngMathsLearnSup = 0,
    R13Total = 0,
    R14MinusEngMaths = 0,
    R14MinusLearningSupport = 0,
    R14MinusEngMathsLearnSup = 0,
    R14Total = 0,

    IncomeToLastPeriodMinusEngMathsLearnSup = 
        CASE
            WHEN FD.ILRReturn = 'R01' THEN 0
            WHEN FD.ILRReturn = 'R02' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 1
            WHEN FD.ILRReturn = 'R03' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 2
            WHEN FD.ILRReturn = 'R04' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 3
            WHEN FD.ILRReturn = 'R05' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 4
            WHEN FD.ILRReturn = 'R06' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 5
            WHEN FD.ILRReturn = 'R07' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 6
            WHEN FD.ILRReturn = 'R08' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 7
            WHEN FD.ILRReturn = 'R09' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 8
            WHEN FD.ILRReturn = 'R10' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 9
            WHEN FD.ILRReturn = 'R11' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 10
            WHEN FD.ILRReturn = 'R12' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 11
            WHEN FD.ILRReturn = 'R13' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 12
            WHEN FD.ILRReturn = 'R14' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 12
            ELSE 0
        END,

    IncomeToLastPeriod = 0,

    IncomeToCurrentPeriodMinusEngMathsLearnSup = 
        CASE
            WHEN FD.ILRReturn = 'R01' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 1
            WHEN FD.ILRReturn = 'R02' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 2
            WHEN FD.ILRReturn = 'R03' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 3
            WHEN FD.ILRReturn = 'R04' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 4
            WHEN FD.ILRReturn = 'R05' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 5
            WHEN FD.ILRReturn = 'R06' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 6
            WHEN FD.ILRReturn = 'R07' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 7
            WHEN FD.ILRReturn = 'R08' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 8
            WHEN FD.ILRReturn = 'R09' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 9
            WHEN FD.ILRReturn = 'R10' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 10
            WHEN FD.ILRReturn = 'R11' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 11
            WHEN FD.ILRReturn = 'R12' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 12
            WHEN FD.ILRReturn = 'R13' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 12
            WHEN FD.ILRReturn = 'R14' THEN ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 12
            ELSE 0
        END,

    IncomeToCurrentPeriod = 0,

    IncomeToFinalPeriodMinusEngMathsLearnSup = 
        ( ( FD.LearnerEnglishMathsFundingRate * FD.LearnerEnglishMathsInstances ) / 12 ) * 12,

    IncomeToFinalPeriod = 0,
    FutureAchievePayment = 0,

    CoreProgrammeFunding = 0,
	TotalProgrammeFunding = 0,

    PrvRetentFactHist = FD.PrvRetentFactHist,
    ProgWeightHist = FD.ProgWeightHist,
    ProgWeightNew = 0,
    LearnerEnglishMathsFundingRate = 0,
    LearnerEnglishMathsInstances = 0,
    EnglishAndMathsFunding = 0,
    Block1DisadvUpliftRate = 0, --Post Codes
    Block1DisadvUpliftCash = 0,
    Block2DisadvUpliftRate = 0,
    Block2DisadvElementsNew = 0,
    Block2DisadvUpliftCash = 0, --English and Maths Low Ach
    LargeProgrammeUplift = FD.LargeProgrammeUplift,
    AreaCostFact1618Hist = FD.AreaCostFact1618Hist,
    ConditionOfFundingAdjustment = FD.ConditionOfFundingAdjustment,
    AdvancedMathsPremium = FD.AdvancedMathsPremium,
    CoreMathsPremium = FD.CoreMathsPremium,
    HighValueCoursePremium = 0,
    TLevelIndustryPlacementFunding = FD.TLevelIndustryPlacementFunding
FROM FIS_FundingData FD
INNER JOIN FIS_FundingDataExtra FDE
    ON FDE.ProviderNumber = FD.ProviderNumber
    AND FDE.AcademicYear = FD.AcademicYear
    AND FDE.ILRReturn = FD.ILRReturn
    AND FDE.ILRReturnDate = FD.ILRReturnDate
    AND FDE.LearnRefNumber = FD.LearnRefNumber
    AND FDE.AimSeqNumber = FD.AimSeqNumber
LEFT JOIN [EBS-DB\EBS].ebs.dbo.ORGANISATION_UNITS CA
    ON CA.ORGANISATION_CODE = 'C08'
LEFT JOIN [EBS-DB\EBS].ebs.dbo.ORGANISATION_UNITS TEAM
    ON TEAM.ORGANISATION_CODE = 'KEYSK'
LEFT JOIN [EBS-DB\EBS].ebs.dbo.PEOPLE CAO
	ON CAO.PERSON_CODE = CA.FES_DEPARTMENT_HEAD
LEFT JOIN [EBS-DB\EBS].ebs.dbo.PEOPLE TEAMO
	ON TEAMO.PERSON_CODE = TEAM.FES_DEPARTMENT_HEAD
LEFT JOIN (
    SELECT
        TAR.TeamCode,
        TAR.Measure,
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    GROUP BY
        TAR.TeamCode,
        TAR.Measure
) TAR
    ON TAR.TeamCode = CA.ORGANISATION_CODE
    AND TAR.Measure = 50101
LEFT JOIN (
    SELECT
        TAR.Measure,
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    GROUP BY
        TAR.Measure
) TARF
    ON TARF.Measure = 50101
LEFT JOIN (
    SELECT
        TAR.Measure,
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    GROUP BY
        TAR.Measure
) TARM
    ON TARM.Measure = 50101
LEFT JOIN (
    SELECT
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
) TART
    ON 1 = 1
WHERE
	FD.AcademicYear = @AcademicYear
	AND FD.ILRReturn = @ILRReturn
	AND FD.IsFinalReturn = @IsFinalReturn
    AND ( FD.CollegeLevel1Code IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    AND ( FD.CollegeLevel2Code IN ( @Team ) OR 'ALL' IN ( @Team ) )
    AND FD.FundLineCategory = '16-19 Funding'
    AND FD.LearnerEnglishMathsFundingRate &gt; 0
	AND FD.IsFundedStart = 1
    --AND FD.LearnRefNumber = '113736'

UNION ALL

SELECT
	ProviderNumber = FD.ProviderNumber,
    ProviderName = FD.providerName,
    AcademicYear = FD.AcademicYear,
	ILRReturn = FD.ILRReturn,
	ILRReturnDate = FD.ILRReturnDate,
    LastILRReturn = 'R' + FORMAT ( CAST ( RIGHT ( FD.ILRReturn, 2 ) AS INT ) - 1, '#00' ),
    RecordType = 'Learning Support',
    RecordTypeOrder = 3,
	CurriculumAreaCode = CA.ORGANISATION_CODE,
	CurriculumAreaName = CA.FES_FULL_NAME,
    CurriculumAreaHead = CAO.FORENAME + ' ' + CAO.SURNAME + ' (' + CAO.FES_STAFF_CODE + ')',
	TeamCode = TEAM.ORGANISATION_CODE,
	TeamName = TEAM.FES_FULL_NAME,
    TeamHead = TEAMO.FORENAME + ' ' + TEAMO.SURNAME + ' (' + TEAMO.FES_STAFF_CODE + ')',
	FundLineCategoryOrder = FD.FundLineCategoryOrder,
	FundLineCategory = FD.FundLineCategory,
	FundLineSubCategoryOrder = FD.FundLineSubCategoryOrder,
	FundLineSubCategory = FundLineSubCategory,
	FundLine = FD.FundLine,
    FundingType = FD.FundLineSubCategory,
    NominalCode = 50101,
    FundCode = 'F-001',
    BudgetTotal = COALESCE ( TART.Budget, 0 ),
    BudgetFundLineCategory = COALESCE ( TARF.Budget, 0 ),
    BudgetMeasure = COALESCE ( TARM.Budget, 0 ),
    BudgetCurriculumAreaAndMeasure = COALESCE ( TAR.Budget, 0 ),
    TargetTotal = COALESCE ( TART.Target, 0 ),
    TargetFundLineCategory = COALESCE ( TARF.Target, 0 ),
    TargetMeasure = COALESCE ( TARM.Target, 0 ),
    TargetCurriculumAreaAndMeasure = COALESCE ( TAR.Target, 0 ),
    StandardCode = FD.StandardCode,
    StandardName = FD.StandardName,
    LearningAimCode = FD.LearningAimCode,
    LearningAimTitle = FD.LearningAimTitle,
    StandardAimCode = COALESCE ( CAST ( FD.StandardCode AS VARCHAR(50) ), FD.LearningAimCode ),
    StandardAimTitle = COALESCE ( FD.StandardName, FD.LearningAimTitle ),
	CourseCode = FD.CourseCode,
	CourseTitle = FD.CourseTitle,
	CourseInstance = FD.CourseInstance,
	CarryIn = CASE WHEN FD.IsCarryIn = 1 THEN 'Carry In' ELSE 'New Start' END,
    FD.LearnRefNumber,
    FD.Surname,
    FD.Forename,
    FD.IsFundedStart,
    FD.IsMainAimInFundModel,
    FD.IsMainAim,
    R01MinusEngMaths = 0,
    R01MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R01MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R01Total = 0,
    R02MinusEngMaths = 0,
    R02MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R02MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R02Total = 0,
    R03MinusEngMaths = 0,
    R03MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R03MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R03Total = 0,
    R04MinusEngMaths = 0,
    R04MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R04MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R04Total = 0,
    R05MinusEngMaths = 0,
    R05MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R05MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R05Total = 0,
    R06MinusEngMaths = 0,
    R06MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R06MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R06Total = 0,
    R07MinusEngMaths = 0,
    R07MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R07MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R07Total = 0,
    R08MinusEngMaths = 0,
    R08MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R08MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R08Total = 0,
    R09MinusEngMaths = 0,
    R09MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R09MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R09Total = 0,
    R10MinusEngMaths = 0,
    R10MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R10MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R10Total = 0,
    R11MinusEngMaths = 0,
    R11MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R11MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R11Total = 0,
    R12MinusEngMaths = 0,
    R12MinusLearningSupport = CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12,
    R12MinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ),
    R12Total = 0,
    R13MinusEngMaths = 0,
    R13MinusLearningSupport = 0,
    R13MinusEngMathsLearnSup = 0,
    R13Total = 0,
    R14MinusEngMaths = 0,
    R14MinusLearningSupport = 0,
    R14MinusEngMathsLearnSup = 0,
    R14Total = 0,

    IncomeToLastPeriodMinusEngMathsLearnSup = 
        CASE
            WHEN FD.ILRReturn = 'R01' THEN 0
            WHEN FD.ILRReturn = 'R02' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 1
            WHEN FD.ILRReturn = 'R03' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 2
            WHEN FD.ILRReturn = 'R04' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 3
            WHEN FD.ILRReturn = 'R05' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 4
            WHEN FD.ILRReturn = 'R06' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 5
            WHEN FD.ILRReturn = 'R07' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 6
            WHEN FD.ILRReturn = 'R08' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 7
            WHEN FD.ILRReturn = 'R09' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 8
            WHEN FD.ILRReturn = 'R10' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 9
            WHEN FD.ILRReturn = 'R11' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 10
            WHEN FD.ILRReturn = 'R12' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 11
            WHEN FD.ILRReturn = 'R13' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 12
            WHEN FD.ILRReturn = 'R14' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 12
            ELSE 0
        END,

    IncomeToLastPeriod = 0,

    IncomeToCurrentPeriodMinusEngMathsLearnSup = 
        CASE
            WHEN FD.ILRReturn = 'R01' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 1
            WHEN FD.ILRReturn = 'R02' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 2
            WHEN FD.ILRReturn = 'R03' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 3
            WHEN FD.ILRReturn = 'R04' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 4
            WHEN FD.ILRReturn = 'R05' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 5
            WHEN FD.ILRReturn = 'R06' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 6
            WHEN FD.ILRReturn = 'R07' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 7
            WHEN FD.ILRReturn = 'R08' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 8
            WHEN FD.ILRReturn = 'R09' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 9
            WHEN FD.ILRReturn = 'R10' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 10
            WHEN FD.ILRReturn = 'R11' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 11
            WHEN FD.ILRReturn = 'R12' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 12
            WHEN FD.ILRReturn = 'R13' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 12
            WHEN FD.ILRReturn = 'R14' THEN ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 12
            ELSE 0
        END,

    IncomeToCurrentPeriod = 0,

    IncomeToFinalPeriodMinusEngMathsLearnSup = 
        ( CASE WHEN COALESCE ( FD.FAMLearnerHNS, FD.FAMLearnerEHC, FD.FAMLearnerLSR ) IS NOT NULL THEN FD.Block1DisadvUpliftCash ELSE 0 END / 12 ) * 12,

    IncomeToFinalPeriod = 0,
    FutureAchievePayment = 0,

    CoreProgrammeFunding = 0,
	TotalProgrammeFunding = 0,

    PrvRetentFactHist = FD.PrvRetentFactHist,
    ProgWeightHist = FD.ProgWeightHist,
    ProgWeightNew = 0,
    LearnerEnglishMathsFundingRate = 0,
    LearnerEnglishMathsInstances = 0,
    EnglishAndMathsFunding = 0,
    Block1DisadvUpliftRate = 0, --Post Codes
    Block1DisadvUpliftCash = 0,
    Block2DisadvUpliftRate = 0,
    Block2DisadvElementsNew = 0,
    Block2DisadvUpliftCash = 0, --English and Maths Low Ach
    LargeProgrammeUplift = FD.LargeProgrammeUplift,
    AreaCostFact1618Hist = FD.AreaCostFact1618Hist,
    ConditionOfFundingAdjustment = FD.ConditionOfFundingAdjustment,
    AdvancedMathsPremium = FD.AdvancedMathsPremium,
    CoreMathsPremium = FD.CoreMathsPremium,
    HighValueCoursePremium = 0,
    TLevelIndustryPlacementFunding = FD.TLevelIndustryPlacementFunding
FROM FIS_FundingData FD
INNER JOIN FIS_FundingDataExtra FDE
    ON FDE.ProviderNumber = FD.ProviderNumber
    AND FDE.AcademicYear = FD.AcademicYear
    AND FDE.ILRReturn = FD.ILRReturn
    AND FDE.ILRReturnDate = FD.ILRReturnDate
    AND FDE.LearnRefNumber = FD.LearnRefNumber
    AND FDE.AimSeqNumber = FD.AimSeqNumber
LEFT JOIN [EBS-DB\EBS].ebs.dbo.ORGANISATION_UNITS CA
    ON CA.ORGANISATION_CODE = 'C10'
LEFT JOIN [EBS-DB\EBS].ebs.dbo.ORGANISATION_UNITS TEAM
    ON TEAM.ORGANISATION_CODE = 'LEARNSUP'
LEFT JOIN [EBS-DB\EBS].ebs.dbo.PEOPLE CAO
	ON CAO.PERSON_CODE = CA.FES_DEPARTMENT_HEAD
LEFT JOIN [EBS-DB\EBS].ebs.dbo.PEOPLE TEAMO
	ON TEAMO.PERSON_CODE = TEAM.FES_DEPARTMENT_HEAD
LEFT JOIN (
    SELECT
        TAR.TeamCode,
        TAR.Measure,
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    GROUP BY
        TAR.TeamCode,
        TAR.Measure
) TAR
    ON TAR.TeamCode = CA.ORGANISATION_CODE
    AND TAR.Measure = 50101
LEFT JOIN (
    SELECT
        TAR.Measure,
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    GROUP BY
        TAR.Measure
) TARF
    ON TARF.Measure = 50101
LEFT JOIN (
    SELECT
        TAR.Measure,
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    GROUP BY
        TAR.Measure
) TARM
    ON TARM.Measure = 50101
LEFT JOIN (
    SELECT
        Budget = SUM ( CASE WHEN TAR.ILRReturn &lt;= @ILRReturn THEN TAR.Target ELSE 0 END ),
        Target = SUM ( TAR.Target )
    FROM FIS_TeamTargets TAR
    WHERE
        TAR.AcademicYear = @AcademicYear
        AND ( TAR.TeamCode IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
) TART
    ON 1 = 1
WHERE
	FD.AcademicYear = @AcademicYear
	AND FD.ILRReturn = @ILRReturn
	AND FD.IsFinalReturn = @IsFinalReturn
    AND ( FD.CollegeLevel1Code IN ( @CurriculumArea ) OR 'ALL' IN ( @CurriculumArea ) )
    AND ( FD.CollegeLevel2Code IN ( @Team ) OR 'ALL' IN ( @Team ) )
    AND FD.FundLineCategory = '16-19 Funding'
    AND FD.Block1DisadvUpliftCash + FD.Block2DisadvUpliftCash &gt; 0
	AND FD.IsFundedStart = 1
    --AND FD.LearnRefNumber = '113736'

UNION ALL

